@attribute [Route($"{MenuRoutes.Prefix}/{nameof(StandaloneReplacementItemGroupList)}")]
@attribute [Authorize]
@inject IOptions<MenuWebOptions> MenuOptionsAccessor

<ShiftList EntitySet="@($"{MenuOptions.ResolvedRoutePrefix}StandaloneReplacementItemGroup")"
           Title="Standalone Groups"
           T="StandaloneReplacementItemGroupListDTO"
           Dense
           ComponentType="typeof(StandaloneReplacementItemGroupForm)"
           TypeAuthAction="MenuActionTree.StandaloneReplacementItemGroups"
           ShowIDColumn="true"
           EnableExport>

    <PropertyColumn Property="x => x.Name" Title="Name" />
    <PropertyColumn Property="x => x.MenuCode" Title="Menu Code" />
    <PropertyColumn Property="x => x.LabourCode" Title="Labour Code" />
</ShiftList>

@code {
    private MenuWebOptions MenuOptions => MenuOptionsAccessor.Value;
}
