@using System.ComponentModel.DataAnnotations
@using System.Text
@using System.Text.Json
@using Microsoft.AspNetCore.WebUtilities
@using global::ShiftSoftware.ADP.Menus.Shared.DTOs.MenuVersion
@using global::ShiftSoftware.ADP.Menus.Web.Extensions

@inject IJSRuntime JSRuntime
@inject HttpClient Http
@inject ShiftModal ShiftModal
@inject MessageService MessageService
@inject IMenuCountryProvider CountryProvider
@inject IOptions<MenuWebOptions> MenuOptionsAccessor

<ShiftFormBasic T="MenuDetailReportQueryDTO"
                @bind-Value="theItem"
                @ref="form"
                SubmitText="Generate"
                OnValidSubmit="GenerateMenuDetailReport"
                Title="Menu Detail Report">

    <ShiftAutocomplete Label="Brand"
                       TEntitySet="ShiftSoftware.ShiftIdentity.Core.DTOs.Brand.BrandListDTO"
                       EntitySet="IdentityBrand"
                       BaseUrl="@MenuOptions.IdentityApiUrl"
                       MultiSelect
                       @bind-selectedValues="theItem.Brands" />

    <ValidationMessage For="() => theItem.Brands" />

    @if (ShowCountryUi)
    {
        <MudSelect T="long?" Label="Country" @bind-Value="theItem.CountryID">
            @foreach (var country in countries)
            {
                <MudSelectItem T="long?" Value="@country.Id">@country.Name</MudSelectItem>
            }
        </MudSelect>

        <MudNumericField T="decimal?" Label="Transfer Rate" @bind-Value="theItem.TransferRate" Min="0" Step="0.01m" />
    }

    @if (MenuOptions.Languages.Count > 0)
    {
        <MudSelect T="string" Label="Language" @bind-Value="selectedLanguage" Required="true">
            @foreach (var lang in MenuOptions.Languages)
            {
                <MudSelectItem T="string" Value="@lang.Culture">@lang.Label</MudSelectItem>
            }
        </MudSelect>
    }

    <MudGrid>
        <MudItem xs="12" lg="6">
            <MudCard Elevation="3" Class="pa-4">
                <MudCardHeader>
                    <MudText Typo="Typo.h6">Old Version</MudText>
                </MudCardHeader>
                <MudCardContent>
                    <ShiftAutocomplete Label="Old Version"
                                       TEntitySet="MenuVersionListDTO"
                                       ValueChanged="OldVersionSelected"
                                       EntitySet="@($"{MenuOptions.ResolvedRoutePrefix}MenuVersion")" />

                    <ShiftDateTimePicker Label="Old Version DateTime"
                                         Clearable="true"
                                         For="()=> theItem.OldVersionDateTime"
                                         @bind-DateTimeOffset="theItem.OldVersionDateTime" />
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" lg="6">
            <MudCard Elevation="3" Class="pa-4">
                <MudCardHeader>
                    <MudText Typo="Typo.h6">New Version</MudText>
                </MudCardHeader>
                <MudCardContent>
                    <ShiftAutocomplete Label="New Version"
                                       TEntitySet="MenuVersionListDTO"
                                       ValueChanged="NewVersionSelected"
                                       EntitySet="@($"{MenuOptions.ResolvedRoutePrefix}MenuVersion")" />

                    <ShiftDateTimePicker Label="New Version DateTime"
                                         Clearable="true"
                                         For="()=> theItem.NewVersionDateTime"
                                         @bind-DateTimeOffset="theItem.NewVersionDateTime" />
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>


</ShiftFormBasic>

@code {
    private MenuWebOptions MenuOptions => MenuOptionsAccessor.Value;

    [CascadingParameter]
    internal IMudDialogInstance? MudDialog { get; set; }

    [Required]
    private DateTimeOffset? datetimeToCompareWith;

    private ShiftFormBasic<MenuDetailReportQueryDTO> form = default!;

    private MenuDetailReportQueryDTO theItem = new();
    private IReadOnlyList<CountryInfo> countries = [];
    private bool ShowCountryUi => countries.Count > 1;
    private string? selectedLanguage;

    protected override async Task OnInitializedAsync()
    {
        countries = (await CountryProvider.GetSupportedCountriesAsync()) ?? Array.Empty<CountryInfo>();
        theItem.CountryID = countries.Count == 0 ? 0 : countries.First().Id;
        theItem.TransferRate = 1;
        selectedLanguage = MenuOptions.Languages.FirstOrDefault()?.Culture;
    }

    async Task GenerateMenuDetailReport()
    {
        if (form.Form?.EditContext?.Validate() != true)
            return;

        var baseUri = $"{MenuOptions.ResolvedRoutePrefix}Menu/MenuDetailReportExcel";

        var queryParams = new List<KeyValuePair<string, string?>>()
        {
            new("oldVersionDateTime", theItem.OldVersionDateTime?.ToString()),
            new("newVersionDateTime", theItem.NewVersionDateTime?.ToString()),
            new("countryId", theItem.CountryID?.ToString()),
            new("transferRate", theItem.TransferRate?.ToString()),
        };

        foreach (var brand in theItem.Brands)
            queryParams.Add(new KeyValuePair<string, string?>("brands", brand.Value));

        if (MenuOptions.Languages.Count > 0 && !string.IsNullOrEmpty(selectedLanguage))
            queryParams.Add(new KeyValuePair<string, string?>("language", selectedLanguage));

        var fullUri = QueryHelpers.AddQueryString(baseUri, queryParams);

        var response = await Http.GetAsync(fullUri);
        if (response.IsSuccessStatusCode)
        {
            var excelData = await response.Content.ReadAsByteArrayAsync();
            var fileName = "MenuDetailReport.xlsx";
            var mimeType = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
            var fileUrl = $"data:{mimeType};base64,{Convert.ToBase64String(excelData)}";

            await JSRuntime.InvokeVoidAsync("downloadFileFromUrl", fileUrl, fileName);
        }
        else
        {
            var errorMessage = await response.Content.ReadFromJsonAsync<ShiftEntityResponse>();
            if (errorMessage != null)
            {
                MessageService.Error(errorMessage.Message?.Title, errorMessage.Message?.Title, errorMessage.Message?.Body);
                return;
            }
        }
    }

    void OldVersionSelected(ShiftEntitySelectDTO? value)
    {
        if (!string.IsNullOrWhiteSpace(value?.Value))
        {
            if(DateTimeOffset.TryParse(value.Value, out var parsedDate))
                theItem.OldVersionDateTime = parsedDate;
        }
    }

    void NewVersionSelected(ShiftEntitySelectDTO? value)
    {
        if (!string.IsNullOrWhiteSpace(value?.Value))
        {
            if (DateTimeOffset.TryParse(value.Value, out var parsedDate))
                theItem.NewVersionDateTime = parsedDate;
        }
    }
}
