@attribute [Route($"{MenuRoutes.Prefix}/{nameof(LabourRateMappingList)}")]
@attribute [Authorize]
@inject MenuWebOptions MenuOptions

<ShiftList EntitySet="@($"{MenuOptions.ResolvedRoutePrefix}LabourRateMapping")"
           Title="Labour Rate Mapping"
           T="LabourRateMappingListDTO"
           Dense
           ComponentType="typeof(LabourRateMappingForm)"
           TypeAuthAction="MenuActionTree.LabourRateMappings"
           ShowIDColumn="true"
           EnableExport>

    <PropertyColumn Property="x => x.Code" Title="Code" />
    <PropertyColumn Property="x => x.LabourRate" Title="Labour Rate" Format="N0" />

    <ForeignColumn Title="Brand"
                   T="LabourRateMappingListDTO"
                   Filterable="false"
                   CellClass="whitespace-nowrap"
                   TEntity="ShiftSoftware.ShiftIdentity.Core.DTOs.Company.CompanyListDTO"
                   EntitySet="IdentityBrand"
                   BaseUrl="@MenuOptions.IdentityApiUrl"
                   TProperty="string"
                   Property="x=> x.BrandID" />
</ShiftList>

