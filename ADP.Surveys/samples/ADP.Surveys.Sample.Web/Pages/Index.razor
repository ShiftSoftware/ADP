@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<MudContainer MaxWidth="MaxWidth.Medium" Class="pt-8">
    <MudText Typo="Typo.h3" GutterBottom="true">ADP.Surveys Sample</MudText>
    <MudText Typo="Typo.body1">
        Sample consumer app for the Surveys module. Use the side menu to reach the builder pages.
    </MudText>

    <MudPaper Class="pa-4 mt-6" Outlined="true">
        <MudText Typo="Typo.h6" GutterBottom="true">Quick links</MudText>
        <MudNavLink Href="/Surveys/SurveyList" Icon="@Icons.Material.Filled.ListAlt">
            Surveys
        </MudNavLink>
        <MudNavLink Href="/Surveys/BankQuestionList" Icon="@Icons.Material.Filled.QuestionAnswer">
            Question Bank
        </MudNavLink>
        <MudNavLink Href="/Surveys/ScreenTemplateList" Icon="@Icons.Material.Filled.ViewQuilt">
            Screen Templates
        </MudNavLink>
    </MudPaper>

    <MudAlert Severity="Severity.Info" Class="mt-6">
        <b>MVP status:</b> Survey authoring is a JSON editor for now. Proper nested
        screen/question/logic editor + LocalizedField + navigationList editor are deferred
        to the next UI pass. Bank &amp; Template CRUD uses the JSON-for-complex-shape pattern too.
    </MudAlert>
</MudContainer>
