@namespace ShiftSoftware.ADP.Surveys.Web.Components
@using ShiftSoftware.ADP.Surveys.Shared.DTOs.Logic

@*
    Dispatches on the three condition shapes and recurses into composite
    children — every node in the condition tree gets the same editor, so
    composites nest to arbitrary depth (visually capped at MaxVisualDepth;
    deeper trees fall back to the Raw JSON pointer).

    Depth 0 is the rule root: it renders the IF label and the full labeled
    shape menu, and shape switches propagate through OnReplaceRoot so the
    parent stores the new reference on LogicRuleDto.If. Children (Depth > 0)
    render a compact icon shape menu and replace themselves in-place inside
    the parent composite's child list.

    Switching to/from expression mode drops the previous content (a
    free-form expression can't be mapped back to a predicate without
    parsing it).
*@

@{
    var currentShape = Condition switch
    {
        PredicateConditionDto => "predicate",
        CompositeConditionDto => "composite",
        ExpressionConditionDto => "expression",
        _ => "predicate",
    };

    // Shape-switch menu, shared across all three branches. Declared at the
    // top of the template so the @if branches below can invoke it; pure
    // Razor so EventCallback types land correctly (an earlier
    // RenderTreeBuilder version tripped InvalidCastException setting
    // OnClick on MudMenuItem). Compact (icon-only) at child depths, labeled
    // at the root.
    RenderFragment<string> ShapeMenu = (current) => @<text>
        <MudMenu Label="@(Depth == 0 ? ShapeLabel(current) : null)"
                 Icon="@(Depth == 0 ? null : Icons.Material.Filled.SwapHoriz)"
                 EndIcon="@(Depth == 0 ? Icons.Material.Filled.KeyboardArrowDown : null)"
                 Variant="Variant.Outlined"
                 Size="Size.Small"
                 Disabled="@ReadOnly"
                 title="Change condition shape"
                 Dense="true">
            <MudMenuItem Disabled="@(current == "predicate")"
                         OnClick="@(() => SwitchShape("predicate"))">
                Single predicate
            </MudMenuItem>
            <MudMenuItem Disabled="@(current == "composite")"
                         OnClick="@(() => SwitchShape("composite"))">
                All of / any of (composite)
            </MudMenuItem>
            <MudMenuItem Disabled="@(current == "expression")"
                         OnClick="@(() => SwitchShape("expression"))">
                Sandbox expression
            </MudMenuItem>
        </MudMenu>
    </text>;
}

@if (Depth > MaxVisualDepth)
{
    <MudAlert Severity="Severity.Warning" Dense="true">
        Condition nested deeper than the visual editor supports.
        Edit via the <b>Raw JSON</b> tab.
    </MudAlert>
}
else if (Condition is PredicateConditionDto pred)
{
    @if (Depth == 0)
    {
        <div class="cond-shell" style="@ShellStyle">
            <div class="cond-shell__toolbar">
                <span class="cond-shell__mode-label">IF</span>
                @ShapeMenu(currentShape)
            </div>
            <LogicPredicateEditor Predicate="pred"
                                  QuestionChoices="QuestionChoices"
                                  FreeKeyMode="@FreeKeyMode"
                                  ReadOnly="@ReadOnly"
                                  Changed="Changed" />
        </div>
    }
    else
    {
        @* Child predicate: single row, compact convert menu inline so a
           composite of N predicates stays N rows tall. *@
        <div class="cond-inline">
            <div class="cond-inline__body">
                <LogicPredicateEditor Predicate="pred"
                                      QuestionChoices="QuestionChoices"
                                      FreeKeyMode="@FreeKeyMode"
                                      ReadOnly="@ReadOnly"
                                      Changed="Changed" />
            </div>
            @ShapeMenu(currentShape)
        </div>
    }
}
else if (Condition is CompositeConditionDto comp)
{
    var children = comp.All ?? comp.Any ?? new List<LogicConditionDto>();
    var mode = comp.All is not null ? "all" : "any";

    <div class="cond-shell" style="@ShellStyle">
        <div class="cond-shell__toolbar">
            @if (Depth == 0)
            {
                <span class="cond-shell__mode-label">IF</span>
            }
            <MudToggleGroup T="string"
                            SelectionMode="SelectionMode.SingleSelection"
                            Value="@mode"
                            ValueChanged="@(async (string m) => await SwitchCompositeMode(comp, m))"
                            Color="Color.Primary"
                            Size="Size.Small"
                            CheckMark="false"
                            Disabled="@ReadOnly">
                <MudToggleItem T="string" Value="@("all")">Match ALL of</MudToggleItem>
                <MudToggleItem T="string" Value="@("any")">Match ANY of</MudToggleItem>
            </MudToggleGroup>
            @ShapeMenu(currentShape)
        </div>

        <div class="cond-shell__children">
            @for (int i = 0; i < children.Count; i++)
            {
                var idx = i;
                var child = children[idx];
                <div class="cond-shell__child" @key="child" style="@ChildStyle">
                    <div class="cond-shell__child-handle">@(idx + 1)</div>
                    <div class="cond-shell__child-body">
                        <LogicConditionEditor Condition="child"
                                              QuestionChoices="QuestionChoices"
                                              FreeKeyMode="@FreeKeyMode"
                                              ReadOnly="@ReadOnly"
                                              Depth="@(Depth + 1)"
                                              OnReplaceRoot="@((LogicConditionDto v) => ReplaceChild(comp, idx, v))"
                                              Changed="Changed" />
                    </div>
                    @if (!ReadOnly)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="@(() => RemoveChild(comp, idx))"
                                       title="Remove condition" />
                    }
                </div>
            }
            @if (!ReadOnly)
            {
                <div class="cond-shell__add-row">
                    <MudButton StartIcon="@Icons.Material.Filled.Add"
                               Size="Size.Small"
                               Variant="Variant.Text"
                               Color="Color.Primary"
                               OnClick="@(() => AddChild(comp))">
                        Add condition
                    </MudButton>
                    @if (Depth < MaxVisualDepth)
                    {
                        <MudButton StartIcon="@Icons.Material.Filled.AccountTree"
                                   Size="Size.Small"
                                   Variant="Variant.Text"
                                   Color="Color.Primary"
                                   OnClick="@(() => AddGroup(comp))">
                            Add nested group
                        </MudButton>
                    }
                </div>
            }
        </div>
    </div>
}
else if (Condition is ExpressionConditionDto expr)
{
    <div class="cond-shell" style="@ShellStyle">
        <div class="cond-shell__toolbar">
            @if (Depth == 0)
            {
                <span class="cond-shell__mode-label">IF</span>
            }
            @ShapeMenu(currentShape)
        </div>
        <LogicExpressionEditor Condition="expr"
                               QuestionChoices="QuestionChoices"
                               ReadOnly="@ReadOnly"
                               Changed="Changed" />
    </div>
}


<style>
    .cond-shell {
        display: flex;
        flex-direction: column;
        gap: 8px;
        border: 1px solid #e0e5ec;
        border-radius: 8px;
        padding: 10px 12px;
    }
    .cond-shell__toolbar {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .cond-shell__mode-label {
        font-weight: 700;
        color: #4338ca;
        font-size: 0.9rem;
    }
    .cond-shell__children {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .cond-shell__child {
        display: grid;
        grid-template-columns: 20px 1fr auto;
        gap: 6px;
        align-items: start;
        border: 1px solid #e0e5ec;
        border-radius: 6px;
        padding: 8px;
    }
    .cond-shell__child-handle {
        font-weight: 600;
        color: #666;
        font-size: 0.8rem;
        padding-top: 10px;
        text-align: right;
    }
    .cond-shell__child-body {
        min-width: 0;
    }
    .cond-shell__add-row {
        display: flex;
        gap: 4px;
    }
    .cond-inline {
        display: flex;
        align-items: start;
        gap: 6px;
    }
    .cond-inline__body {
        flex: 1;
        min-width: 0;
    }
</style>

@code {
    /// <summary>
    /// Beyond this nesting depth the editor stops recursing and points at the
    /// Raw JSON tab. Keeps pathological trees from producing unusable UI.
    /// </summary>
    const int MaxVisualDepth = 4;

    [Parameter, EditorRequired]
    public LogicConditionDto Condition { get; set; } = default!;

    [Parameter]
    public IReadOnlyList<LogicPredicateEditor.QuestionChoice> QuestionChoices { get; set; }
        = Array.Empty<LogicPredicateEditor.QuestionChoice>();

    [Parameter]
    public bool ReadOnly { get; set; }

    /// <summary>
    /// Open key domain (trigger-filter context paths) — passed through to
    /// every <see cref="LogicPredicateEditor"/> in the tree.
    /// </summary>
    [Parameter]
    public bool FreeKeyMode { get; set; }

    /// <summary>
    /// Nesting level of this node. 0 = rule root (renders the IF label);
    /// deeper levels are children of a composite and replace themselves
    /// inside the parent's child list on shape switch.
    /// </summary>
    [Parameter]
    public int Depth { get; set; }

    /// <summary>
    /// Invoked when this node's condition reference changes (shape switch).
    /// At the root the parent writes the new value back onto LogicRuleDto.If;
    /// at child depths the parent composite replaces the child in its list.
    /// </summary>
    [Parameter]
    public EventCallback<LogicConditionDto> OnReplaceRoot { get; set; }

    [Parameter]
    public EventCallback Changed { get; set; }

    // Alternate shell backgrounds by depth parity so nested groups read as
    // distinct layers.
    string ShellStyle => Depth % 2 == 0 ? "background: #f7f8fa;" : "background: #fff;";
    string ChildStyle => Depth % 2 == 0 ? "background: #fff;" : "background: #f7f8fa;";

    static string ShapeLabel(string shape) => shape switch
    {
        "predicate" => "Single predicate",
        "composite" => "Composite",
        "expression" => "Expression",
        _ => shape,
    };

    async Task SwitchShape(string target)
    {
        LogicConditionDto replacement = target switch
        {
            "predicate" => new PredicateConditionDto(),
            "composite" => new CompositeConditionDto { All = new List<LogicConditionDto> { new PredicateConditionDto() } },
            "expression" => new ExpressionConditionDto { Expression = "" },
            _ => Condition,
        };
        if (ReferenceEquals(replacement, Condition)) return;
        await OnReplaceRoot.InvokeAsync(replacement);
    }

    async Task SwitchCompositeMode(CompositeConditionDto comp, string newMode)
    {
        var children = comp.All ?? comp.Any ?? new List<LogicConditionDto>();
        if (newMode == "all")
        {
            comp.All = children;
            comp.Any = null;
        }
        else
        {
            comp.Any = children;
            comp.All = null;
        }
        await Changed.InvokeAsync();
    }

    async Task AddChild(CompositeConditionDto comp)
    {
        GetOrCreateChildren(comp).Add(new PredicateConditionDto());
        await Changed.InvokeAsync();
    }

    async Task AddGroup(CompositeConditionDto comp)
    {
        GetOrCreateChildren(comp).Add(new CompositeConditionDto
        {
            All = new List<LogicConditionDto> { new PredicateConditionDto() },
        });
        await Changed.InvokeAsync();
    }

    static List<LogicConditionDto> GetOrCreateChildren(CompositeConditionDto comp)
    {
        var children = comp.All ?? comp.Any;
        if (children is null)
        {
            children = new List<LogicConditionDto>();
            comp.All = children;
        }
        return children;
    }

    async Task ReplaceChild(CompositeConditionDto comp, int index, LogicConditionDto replacement)
    {
        var children = comp.All ?? comp.Any;
        if (children is null || index < 0 || index >= children.Count) return;
        children[index] = replacement;
        await Changed.InvokeAsync();
    }

    async Task RemoveChild(CompositeConditionDto comp, int index)
    {
        var children = comp.All ?? comp.Any;
        if (children is null || index < 0 || index >= children.Count) return;
        children.RemoveAt(index);
        await Changed.InvokeAsync();
    }
}
