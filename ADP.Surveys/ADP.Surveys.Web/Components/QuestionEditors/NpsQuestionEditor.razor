@namespace ShiftSoftware.ADP.Surveys.Web.Components.QuestionEditors
@using ShiftSoftware.ADP.Surveys.Shared.DTOs.Questions.Types
@using LocalizedString = ShiftSoftware.ADP.Surveys.Shared.DTOs.LocalizedString

<QuestionCommonFields Question="@Question"
                      Locales="@Locales"
                      ReadOnly="@ReadOnly"
                      Changed="Changed" />

<div class="qte-section">
    <div class="qte-section__title">NPS scale</div>
    <div class="qte-row">
        <MudNumericField T="int"
                         Label="Min"
                         Value="@Question.Min"
                         ValueChanged="@((int v) => OnChanged(() => Question.Min = v))"
                         ReadOnly="@ReadOnly"
                         Min="0"
                         Max="20"
                         Class="qte-num" />
        <MudNumericField T="int"
                         Label="Max"
                         Value="@Question.Max"
                         ValueChanged="@((int v) => OnChanged(() => Question.Max = v))"
                         ReadOnly="@ReadOnly"
                         Min="1"
                         Max="20"
                         Class="qte-num" />
    </div>

    <LocalizedStringField Value="@Question.LowLabel"
                          ValueChanged="@((LocalizedString? v) => OnChanged(() => Question.LowLabel = v))"
                          Label="Low-end label (optional)"
                          Locales="@Locales"
                          ReadOnly="@ReadOnly" />

    <LocalizedStringField Value="@Question.HighLabel"
                          ValueChanged="@((LocalizedString? v) => OnChanged(() => Question.HighLabel = v))"
                          Label="High-end label (optional)"
                          Locales="@Locales"
                          ReadOnly="@ReadOnly" />
</div>

<style>
    .qte-section {
        margin-top: 14px;
        padding-top: 10px;
        border-top: 1px dashed #e0e5ec;
    }
    .qte-section__title {
        font-size: 0.8rem;
        font-weight: 600;
        color: #4b5563;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 8px;
    }
    .qte-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }
    .qte-num { flex: 1 1 120px; min-width: 100px; }
</style>

@code {
    [Parameter, EditorRequired]
    public NpsQuestionDto Question { get; set; } = default!;

    [Parameter]
    public List<string>? Locales { get; set; }

    [Parameter]
    public bool ReadOnly { get; set; }

    [Parameter]
    public EventCallback Changed { get; set; }

    async Task OnChanged(Action mutation)
    {
        mutation();
        await Changed.InvokeAsync();
    }
}
