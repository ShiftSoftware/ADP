@namespace ShiftSoftware.ADP.Surveys.Web.Components.QuestionEditors
@using ShiftSoftware.ADP.Surveys.Shared.DTOs.Questions.Types
@using LocalizedString = ShiftSoftware.ADP.Surveys.Shared.DTOs.LocalizedString

<QuestionCommonFields Question="@Question"
                      Locales="@Locales"
                      ReadOnly="@ReadOnly"
                      Changed="Changed" />

<div class="qte-section">
    <div class="qte-section__title">Button labels (optional)</div>
    <LocalizedStringField Value="@Question.YesLabel"
                          ValueChanged="@((LocalizedString? v) => OnChanged(() => Question.YesLabel = v))"
                          Label='Yes-button label'
                          Locales="@Locales"
                          ReadOnly="@ReadOnly" />

    <LocalizedStringField Value="@Question.NoLabel"
                          ValueChanged="@((LocalizedString? v) => OnChanged(() => Question.NoLabel = v))"
                          Label='No-button label'
                          Locales="@Locales"
                          ReadOnly="@ReadOnly" />
</div>

<style>
    .qte-section { margin-top: 14px; padding-top: 10px; border-top: 1px dashed #e0e5ec; }
    .qte-section__title { font-size: 0.8rem; font-weight: 600; color: #4b5563; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
</style>

@code {
    [Parameter, EditorRequired]
    public YesNoQuestionDto Question { get; set; } = default!;

    [Parameter]
    public List<string>? Locales { get; set; }

    [Parameter]
    public bool ReadOnly { get; set; }

    [Parameter]
    public EventCallback Changed { get; set; }

    async Task OnChanged(Action mutation)
    {
        mutation();
        await Changed.InvokeAsync();
    }
}
