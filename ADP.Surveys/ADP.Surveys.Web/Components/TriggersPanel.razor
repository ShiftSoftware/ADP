@namespace ShiftSoftware.ADP.Surveys.Web.Components
@using System.Text.RegularExpressions
@using ShiftSoftware.ADP.Surveys.Shared.DTOs
@using ShiftSoftware.ADP.Surveys.Shared.DTOs.Logic
@using ShiftSoftware.ADP.Surveys.Shared.DTOs.Triggers
@using ShiftSoftware.ADP.Surveys.Web.WebServices

@inject SurveyService SurveySvc

@*
    Survey-level trigger list. Lives as its own toolbar tab alongside General /
    Visual / Logic / Raw. Mirrors the LogicRulesPanel layout (header row +
    info alert + expansion panels).

    Three pieces of polish vs the inline version this replaces:
      - Schedule durations edited via TriggerDurationField (number + unit), not
        free-text duration strings.
      - Channel field is a MudAutocomplete sourced from the registry endpoint
        with free-text fallback.
      - Dedup recipe rows are scope+field pickers matching the four shapes
        documented in TriggerHasher.cs, with inline validation + a cheat-sheet.
*@

<div class="triggers-panel">
    <div class="triggers-panel__header">
        <div class="triggers-panel__title">
            <MudIcon Icon="@Icons.Material.Filled.NotificationsActive" />
            <span>Triggers</span>
            @if (Triggers.Count > 0)
            {
                <MudChip T="string"
                         Size="Size.Small"
                         Color="Color.Info"
                         Variant="Variant.Outlined">@Triggers.Count</MudChip>
            }
        </div>
        @if (!ReadOnly)
        {
            <MudButton StartIcon="@Icons.Material.Filled.Add"
                       Size="Size.Small"
                       Variant="Variant.Text"
                       Color="Color.Primary"
                       OnClick="AddTrigger">
                Add trigger
            </MudButton>
        }
    </div>

    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
        Triggers fire when an upstream event of <b>eventKind</b> arrives. Each materializes a
        survey instance, dedup'd by the recipe, and delivered via the named channel on the
        schedule below.
    </MudAlert>

    @if (Draft is null || Triggers.Count == 0)
    {
        <div class="triggers-panel__empty">
            No triggers yet. Click <b>+ Add trigger</b> to fire a survey instance on an event.
        </div>
    }
    else
    {
        <MudExpansionPanels MultiExpansion="false" Elevation="0" Dense="true">
            @for (int i = 0; i < Triggers.Count; i++)
            {
                var idx = i;
                var trigger = Triggers[idx];

                <MudExpansionPanel Expanded="@(idx == expandedIndex)"
                                   ExpandedChanged="@(b => OnExpandedChanged(idx, b))">
                    <TitleContent>
                        <div class="triggers-panel__row">
                            <div class="triggers-panel__row-label">
                                <span class="triggers-panel__row-number">@(idx + 1).</span>
                                <span class="triggers-panel__row-summary">
                                    @(string.IsNullOrWhiteSpace(trigger.Id) ? "(untitled)" : trigger.Id)
                                    @if (!string.IsNullOrWhiteSpace(trigger.EventKind))
                                    {
                                        <span class="triggers-panel__row-event"> · @trigger.EventKind</span>
                                    }
                                    @if (!trigger.Enabled)
                                    {
                                        <MudChip T="string"
                                                 Size="Size.Small"
                                                 Color="Color.Default"
                                                 Variant="Variant.Outlined"
                                                 Class="ml-2">disabled</MudChip>
                                    }
                                </span>
                            </div>
                            @if (!ReadOnly)
                            {
                                <div class="triggers-panel__row-actions" @onclick:stopPropagation="true">
                                    <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp"
                                                   Size="Size.Small"
                                                   Disabled="@(idx == 0)"
                                                   OnClick="@(() => MoveTrigger(idx, -1))"
                                                   title="Move up" />
                                    <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown"
                                                   Size="Size.Small"
                                                   Disabled="@(idx == Triggers.Count - 1)"
                                                   OnClick="@(() => MoveTrigger(idx, +1))"
                                                   title="Move down" />
                                    <MudSwitch T="bool"
                                               Value="@trigger.Enabled"
                                               ValueChanged="@(v => OnEnabledChanged(idx, v))"
                                               Color="Color.Primary"
                                               Size="Size.Small" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Size="Size.Small"
                                                   Color="Color.Error"
                                                   OnClick="@(() => RemoveTrigger(idx))"
                                                   title="Remove trigger" />
                                </div>
                            }
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <div class="triggers-panel__body">
                            <div class="triggers-panel__grid">
                                <MudTextField T="string"
                                              Label="Id"
                                              HelperText="Stable within the survey (used as SurveyInstance.TriggerId)."
                                              Margin="Margin.Dense"
                                              ReadOnly="@ReadOnly"
                                              Value="@trigger.Id"
                                              ValueChanged="@(v => OnIdChanged(idx, v))" />
                                <MudTextField T="string"
                                              Label="Event kind"
                                              HelperText="e.g. service-visit-closed — matched at ingest."
                                              Margin="Margin.Dense"
                                              ReadOnly="@ReadOnly"
                                              Value="@trigger.EventKind"
                                              ValueChanged="@(v => OnEventKindChanged(idx, v))" />
                            </div>

                            <div class="triggers-panel__grid mt-2">
                                <div>
                                    <MudAutocomplete T="string"
                                                     Label="Channel"
                                                     Margin="Margin.Dense"
                                                     Disabled="@ReadOnly"
                                                     Value="@trigger.Channel"
                                                     ValueChanged="@(v => OnChannelChanged(idx, v))"
                                                     SearchFunc="SearchChannels"
                                                     CoerceText="true"
                                                     CoerceValue="true"
                                                     Clearable="false"
                                                     ResetValueOnEmptyText="false"
                                                     AnchorOrigin="Origin.BottomCenter" />
                                    @if (!string.IsNullOrWhiteSpace(trigger.Channel) && registeredChannels is not null
                                        && !registeredChannels.Contains(trigger.Channel))
                                    {
                                        <div class="triggers-panel__hint triggers-panel__hint--warn">
                                            Not registered in this environment — survey will fail to send until a matching ISurveyChannel is wired up.
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="triggers-panel__hint">
                                            DI key of a registered ISurveyChannel.
                                        </div>
                                    }
                                </div>
                                <TriggerDurationField Value="@trigger.Schedule.InitialDelay"
                                                      ValueChanged="@(v => OnInitialDelayChanged(idx, v))"
                                                      ReadOnly="@ReadOnly"
                                                      Label="Initial delay" />
                            </div>

                            <div class="triggers-panel__sublabel">Reminders</div>
                            <div class="triggers-panel__sublabel-help">
                                Each entry is a duration since the previous send.
                            </div>
                            @for (int r = 0; r < trigger.Schedule.Reminders.Count; r++)
                            {
                                var rIdx = r;
                                <div class="triggers-panel__list-row">
                                    <div class="triggers-panel__list-row-main">
                                        <TriggerDurationField Value="@trigger.Schedule.Reminders[rIdx]"
                                                              ValueChanged="@(v => OnReminderChanged(idx, rIdx, v))"
                                                              ReadOnly="@ReadOnly"
                                                              Label="@($"Reminder {rIdx + 1}")" />
                                    </div>
                                    @if (!ReadOnly)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                       Size="Size.Small"
                                                       OnClick="@(() => RemoveReminder(idx, rIdx))"
                                                       title="Remove reminder" />
                                    }
                                </div>
                            }
                            @if (!ReadOnly)
                            {
                                <MudButton StartIcon="@Icons.Material.Filled.Add"
                                           Size="Size.Small"
                                           Variant="Variant.Text"
                                           OnClick="@(() => AddReminder(idx))">
                                    Add reminder
                                </MudButton>
                            }

                            <div class="triggers-panel__sublabel mt-3">Dedup recipe</div>
                            <div class="triggers-panel__sublabel-help">
                                Field references that combine into the instance's <code>UniqueHash</code> —
                                this is what makes <i>"process each event at most once per recipient"</i> work.
                            </div>

                            <MudExpansionPanels Elevation="0" Dense="true" Class="triggers-panel__cheatsheet">
                                <MudExpansionPanel Text="Recipe grammar cheat-sheet">
                                    <ul class="triggers-panel__cheatsheet-list">
                                        <li><code>templateId</code> — survey ID (useful when one event fires multiple surveys to the same recipient).</li>
                                        <li><code>recipient.address</code> — phone / email / etc. resolved upstream.</li>
                                        <li><code>recipient.locale</code> — recipient's locale.</li>
                                        <li><code>recipient.customerRef</code> — caller-supplied stable recipient ID.</li>
                                        <li><code>candidate.&lt;field&gt;</code> — top-level property on the event payload (e.g. <code>candidate.wip</code>, <code>candidate.dealerId</code>). Nested paths not yet supported.</li>
                                    </ul>
                                </MudExpansionPanel>
                            </MudExpansionPanels>

                            @for (int d = 0; d < trigger.DedupRecipe.Count; d++)
                            {
                                var dIdx = d;
                                var entry = trigger.DedupRecipe[dIdx];
                                var (scope, field) = ParseDedupEntry(entry);
                                var valid = IsDedupEntryValid(entry);

                                <div class="triggers-panel__list-row">
                                    <MudSelect T="string"
                                               Value="@scope"
                                               ValueChanged="@(v => OnDedupScopeChanged(idx, dIdx, v))"
                                               Margin="Margin.Dense"
                                               Disabled="@ReadOnly"
                                               AnchorOrigin="Origin.BottomCenter"
                                               Class="triggers-panel__dedup-scope">
                                        <MudSelectItem T="string" Value="@("templateId")">templateId</MudSelectItem>
                                        <MudSelectItem T="string" Value="@("recipient")">recipient.*</MudSelectItem>
                                        <MudSelectItem T="string" Value="@("candidate")">candidate.*</MudSelectItem>
                                    </MudSelect>

                                    @if (scope == "recipient")
                                    {
                                        <MudSelect T="string"
                                                   Value="@field"
                                                   ValueChanged="@(v => OnDedupFieldChanged(idx, dIdx, v))"
                                                   Margin="Margin.Dense"
                                                   Disabled="@ReadOnly"
                                                   Placeholder="select…"
                                                   AnchorOrigin="Origin.BottomCenter"
                                                   Class="triggers-panel__dedup-field">
                                            <MudSelectItem T="string" Value="@("address")">address</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("locale")">locale</MudSelectItem>
                                            <MudSelectItem T="string" Value="@("customerRef")">customerRef</MudSelectItem>
                                        </MudSelect>
                                    }
                                    else if (scope == "candidate")
                                    {
                                        <MudTextField T="string"
                                                      Value="@field"
                                                      ValueChanged="@(v => OnDedupFieldChanged(idx, dIdx, v))"
                                                      Placeholder="field name (e.g. wip)"
                                                      Margin="Margin.Dense"
                                                      ReadOnly="@ReadOnly"
                                                      Class="triggers-panel__dedup-field" />
                                    }
                                    else
                                    {
                                        @* templateId: no field *@
                                        <div class="triggers-panel__dedup-field-spacer"></div>
                                    }

                                    @if (!valid)
                                    {
                                        <MudChip T="string"
                                                 Size="Size.Small"
                                                 Color="Color.Warning"
                                                 Variant="Variant.Outlined"
                                                 Icon="@Icons.Material.Filled.Warning">
                                            invalid
                                        </MudChip>
                                    }

                                    @if (!ReadOnly)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                       Size="Size.Small"
                                                       OnClick="@(() => RemoveDedupRow(idx, dIdx))"
                                                       title="Remove field" />
                                    }
                                </div>
                            }
                            @if (!ReadOnly)
                            {
                                <MudButton StartIcon="@Icons.Material.Filled.Add"
                                           Size="Size.Small"
                                           Variant="Variant.Text"
                                           OnClick="@(() => AddDedupRow(idx))">
                                    Add field
                                </MudButton>
                            }

                            <div class="triggers-panel__sublabel mt-3">Filter</div>
                            <div class="triggers-panel__sublabel-help">
                                Optional condition evaluated at ingest against the event context
                                (<code>templateId</code>, <code>recipient.*</code>, <code>candidate.*</code>) —
                                the trigger only fires when it matches.
                            </div>
                            @if (trigger.Filter is null)
                            {
                                @if (!ReadOnly)
                                {
                                    <MudButton StartIcon="@Icons.Material.Filled.FilterAlt"
                                               Size="Size.Small"
                                               Variant="Variant.Text"
                                               Color="Color.Primary"
                                               OnClick="@(() => AddFilter(idx))">
                                        Add filter
                                    </MudButton>
                                }
                                else
                                {
                                    <div class="triggers-panel__hint">
                                        No filter — every event of this kind fires the trigger.
                                    </div>
                                }
                            }
                            else
                            {
                                <LogicConditionEditor Condition="trigger.Filter"
                                                      QuestionChoices="@BuildFilterChoices(trigger)"
                                                      FreeKeyMode="true"
                                                      ReadOnly="@ReadOnly"
                                                      OnReplaceRoot="@((LogicConditionDto v) => OnFilterRootReplaced(idx, v))"
                                                      Changed="@(() => OnFilterChanged())" />
                                @if (!ReadOnly)
                                {
                                    <MudButton StartIcon="@Icons.Material.Filled.FilterAltOff"
                                               Size="Size.Small"
                                               Variant="Variant.Text"
                                               Color="Color.Error"
                                               OnClick="@(() => RemoveFilter(idx))">
                                        Remove filter
                                    </MudButton>
                                }
                            }
                        </div>
                    </ChildContent>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>
    }
</div>

