@code {
    [Parameter] public SurveyDto? Draft { get; set; }
    [Parameter] public EventCallback<SurveyDto?> DraftChanged { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public int SchemaVersion { get; set; }

    int expandedIndex = -1;
    List<string>? registeredChannels;

    static readonly Regex DedupGrammar = new(
        @"^(templateId|recipient\.(address|locale|customerRef)|candidate\.[A-Za-z_][A-Za-z0-9_-]*)$",
        RegexOptions.Compiled);

    List<TriggerDto> Triggers => Draft?.Triggers ?? new();

    protected override async Task OnInitializedAsync()
    {
        registeredChannels = await SurveySvc.GetRegisteredChannelsAsync();
    }

    SurveyDto EnsureDraft()
    {
        Draft ??= SurveyDraftFactory.CreateSkeleton();
        return Draft;
    }

    void OnExpandedChanged(int idx, bool expanded) => expandedIndex = expanded ? idx : -1;

    Task<IEnumerable<string>> SearchChannels(string? value, CancellationToken ct)
    {
        var pool = registeredChannels ?? new();
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult<IEnumerable<string>>(pool);
        return Task.FromResult<IEnumerable<string>>(
            pool.Where(k => k.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    // ---- CRUD ----

    async Task AddTrigger()
    {
        var draft = EnsureDraft();
        draft.Triggers.Add(new TriggerDto
        {
            Id = $"trigger-{draft.Triggers.Count + 1}",
            Enabled = true,
            Schedule = new TriggerScheduleDto { InitialDelay = "0d" },
        });
        expandedIndex = draft.Triggers.Count - 1;
        await DraftChanged.InvokeAsync(draft);
    }

    async Task RemoveTrigger(int idx)
    {
        var draft = EnsureDraft();
        if (idx < 0 || idx >= draft.Triggers.Count) return;
        draft.Triggers.RemoveAt(idx);
        if (expandedIndex == idx) expandedIndex = -1;
        else if (expandedIndex > idx) expandedIndex--;
        await DraftChanged.InvokeAsync(draft);
    }

    async Task MoveTrigger(int idx, int delta)
    {
        var draft = EnsureDraft();
        var target = idx + delta;
        if (idx < 0 || idx >= draft.Triggers.Count || target < 0 || target >= draft.Triggers.Count) return;
        (draft.Triggers[idx], draft.Triggers[target]) = (draft.Triggers[target], draft.Triggers[idx]);
        // Keep the expanded panel following the trigger it belonged to.
        if (expandedIndex == idx) expandedIndex = target;
        else if (expandedIndex == target) expandedIndex = idx;
        await DraftChanged.InvokeAsync(draft);
    }

    async Task OnIdChanged(int idx, string value)
    {
        var draft = EnsureDraft();
        draft.Triggers[idx].Id = value ?? "";
        await DraftChanged.InvokeAsync(draft);
    }

    async Task OnEventKindChanged(int idx, string value)
    {
        var draft = EnsureDraft();
        draft.Triggers[idx].EventKind = value ?? "";
        await DraftChanged.InvokeAsync(draft);
    }

    async Task OnChannelChanged(int idx, string value)
    {
        var draft = EnsureDraft();
        draft.Triggers[idx].Channel = value ?? "";
        await DraftChanged.InvokeAsync(draft);
    }

    async Task OnEnabledChanged(int idx, bool value)
    {
        var draft = EnsureDraft();
        draft.Triggers[idx].Enabled = value;
        await DraftChanged.InvokeAsync(draft);
    }

    async Task OnInitialDelayChanged(int idx, string value)
    {
        var draft = EnsureDraft();
        draft.Triggers[idx].Schedule.InitialDelay = value ?? "";
        await DraftChanged.InvokeAsync(draft);
    }

    async Task AddReminder(int idx)
    {
        var draft = EnsureDraft();
        draft.Triggers[idx].Schedule.Reminders.Add("");
        await DraftChanged.InvokeAsync(draft);
    }

    async Task RemoveReminder(int idx, int rIdx)
    {
        var draft = EnsureDraft();
        var list = draft.Triggers[idx].Schedule.Reminders;
        if (rIdx < 0 || rIdx >= list.Count) return;
        list.RemoveAt(rIdx);
        await DraftChanged.InvokeAsync(draft);
    }

    async Task OnReminderChanged(int idx, int rIdx, string value)
    {
        var draft = EnsureDraft();
        draft.Triggers[idx].Schedule.Reminders[rIdx] = value ?? "";
        await DraftChanged.InvokeAsync(draft);
    }

    // ---- Filter ----

    static readonly string[] FixedFilterKeys =
    {
        "templateId",
        "recipient.address",
        "recipient.locale",
        "recipient.customerRef",
    };

    /// <summary>
    /// Suggestion catalog for the filter's field autocomplete: the fixed
    /// context paths plus any keys already referenced by this trigger's
    /// filter tree (so previously-authored candidate.* paths round-trip
    /// into the suggestions).
    /// </summary>
    IReadOnlyList<LogicPredicateEditor.QuestionChoice> BuildFilterChoices(TriggerDto trigger)
    {
        var keys = new List<string>(FixedFilterKeys);
        CollectFilterKeys(trigger.Filter, keys);
        return keys.Distinct()
            .Select(k => new LogicPredicateEditor.QuestionChoice { Id = k, TypeLabel = "" })
            .ToList();
    }

    static void CollectFilterKeys(LogicConditionDto? cond, List<string> into)
    {
        switch (cond)
        {
            case PredicateConditionDto p when !string.IsNullOrWhiteSpace(p.QuestionId):
                into.Add(p.QuestionId);
                break;
            case CompositeConditionDto c:
                foreach (var child in c.All ?? c.Any ?? new List<LogicConditionDto>())
                    CollectFilterKeys(child, into);
                break;
        }
    }

    async Task AddFilter(int idx)
    {
        var draft = EnsureDraft();
        draft.Triggers[idx].Filter = new PredicateConditionDto();
        await DraftChanged.InvokeAsync(draft);
    }

    async Task RemoveFilter(int idx)
    {
        var draft = EnsureDraft();
        draft.Triggers[idx].Filter = null;
        await DraftChanged.InvokeAsync(draft);
    }

    async Task OnFilterRootReplaced(int idx, LogicConditionDto replacement)
    {
        var draft = EnsureDraft();
        draft.Triggers[idx].Filter = replacement;
        await DraftChanged.InvokeAsync(draft);
    }

    async Task OnFilterChanged()
    {
        var draft = EnsureDraft();
        await DraftChanged.InvokeAsync(draft);
    }

    // ---- Dedup recipe ----

    /// <summary>
    /// Splits a recipe entry into (scope, field) for editor binding. Scope is one of
    /// "templateId" | "recipient" | "candidate"; field is the suffix or "".
    /// Falls back to candidate-scope when the input doesn't match the grammar so
    /// a newly-added blank row still renders sensibly.
    /// </summary>
    static (string scope, string field) ParseDedupEntry(string entry)
    {
        if (string.IsNullOrEmpty(entry)) return ("candidate", "");
        if (entry == "templateId") return ("templateId", "");
        if (entry.StartsWith("recipient.", StringComparison.Ordinal))
            return ("recipient", entry["recipient.".Length..]);
        if (entry.StartsWith("candidate.", StringComparison.Ordinal))
            return ("candidate", entry["candidate.".Length..]);
        return ("candidate", entry);
    }

    static bool IsDedupEntryValid(string entry)
        => !string.IsNullOrEmpty(entry) && DedupGrammar.IsMatch(entry);

    static string ComposeDedupEntry(string scope, string field) => scope switch
    {
        "templateId" => "templateId",
        "recipient" => string.IsNullOrEmpty(field) ? "recipient." : $"recipient.{field}",
        "candidate" => string.IsNullOrEmpty(field) ? "candidate." : $"candidate.{field}",
        _ => "",
    };

    async Task AddDedupRow(int idx)
    {
        var draft = EnsureDraft();
        draft.Triggers[idx].DedupRecipe.Add("candidate.");
        await DraftChanged.InvokeAsync(draft);
    }

    async Task RemoveDedupRow(int idx, int dIdx)
    {
        var draft = EnsureDraft();
        var recipe = draft.Triggers[idx].DedupRecipe;
        if (dIdx < 0 || dIdx >= recipe.Count) return;
        recipe.RemoveAt(dIdx);
        await DraftChanged.InvokeAsync(draft);
    }

    async Task OnDedupScopeChanged(int idx, int dIdx, string newScope)
    {
        var draft = EnsureDraft();
        var current = draft.Triggers[idx].DedupRecipe[dIdx];
        var (_, field) = ParseDedupEntry(current);
        // Reset field when switching to/from templateId (no field), or to recipient
        // (free-text won't validate against the fixed enum). Keep candidate's field
        // when coming from another candidate edit so users don't lose what they typed.
        if (newScope == "templateId") field = "";
        else if (newScope == "recipient" && field is not "address" and not "locale" and not "customerRef") field = "";
        draft.Triggers[idx].DedupRecipe[dIdx] = ComposeDedupEntry(newScope, field);
        await DraftChanged.InvokeAsync(draft);
    }

    async Task OnDedupFieldChanged(int idx, int dIdx, string newField)
    {
        var draft = EnsureDraft();
        var current = draft.Triggers[idx].DedupRecipe[dIdx];
        var (scope, _) = ParseDedupEntry(current);
        draft.Triggers[idx].DedupRecipe[dIdx] = ComposeDedupEntry(scope, newField ?? "");
        await DraftChanged.InvokeAsync(draft);
    }
}
