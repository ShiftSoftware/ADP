@using System.Net.Http
@using System.Net.Http.Json
@using System.Text.Json
@using ShiftSoftware.ADP.Surveys.Shared.Json
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject HttpClient Http
@inject SurveysWebOptions SurveysOptions

@*
    Live-preview pane. Hosts the @shiftsoftware/survey-web-component custom
    element and pushes a RESOLVED version of the current draft via JS interop
    whenever the bound Schema parameter changes. Resolution happens server-side
    via POST {prefix}Preview — same SchemaResolver the publish pipeline runs —
    so the preview matches production exactly (banked questions expanded inline,
    screen templates unrolled).

    When Schema is null (empty draft) or resolution errors, we hide the element
    and render a placeholder so the pane isn't a blank white box.
*@

<div class="survey-preview @($"survey-preview--{previewMode}")">
    @*
        Device frame with a mobile / tablet / desktop width toggle. Mobile is
        the primary target (~99% of survey traffic) and renders 1:1. Tablet
        and desktop render at their true logical widths (768 / 1024 px) and
        are scaled down with a CSS transform so the sticky preview rail keeps
        its phone-sized footprint — the renderer sees a real wide viewport,
        the layout doesn't reflow around a giant frame.
    *@
    <div class="survey-preview__toolbar">
        <MudToggleGroup T="string"
                        SelectionMode="SelectionMode.SingleSelection"
                        @bind-Value="previewMode"
                        Color="Color.Primary"
                        Size="Size.Small"
                        CheckMark="false">
            <MudToggleItem T="string" Value="@("mobile")">
                <MudIcon Icon="@Icons.Material.Filled.Smartphone" Size="Size.Small" title="Mobile (375px)" />
            </MudToggleItem>
            <MudToggleItem T="string" Value="@("tablet")">
                <MudIcon Icon="@Icons.Material.Filled.TabletMac" Size="Size.Small" title="Tablet (768px)" />
            </MudToggleItem>
            <MudToggleItem T="string" Value="@("desktop")">
                <MudIcon Icon="@Icons.Material.Filled.DesktopWindows" Size="Size.Small" title="Desktop (1024px)" />
            </MudToggleItem>
        </MudToggleGroup>
    </div>
    <div class="survey-preview__scalebox">
        <div class="survey-preview__device">
            @if (previewMode == "mobile")
            {
                <div class="survey-preview__device-notch"></div>
            }
            <div class="survey-preview__device-screen">
                @if (Schema is null)
                {
                    <div class="survey-preview__placeholder">
                        <em>No valid draft to preview.</em>
                    </div>
                }
                else if (resolveError is not null)
                {
                    <div class="survey-preview__placeholder">
                        <em>Preview unavailable: @resolveError</em>
                    </div>
                }
                else
                {
                    <shift-survey @ref="surveyElement" locale="@Locale"></shift-survey>
                }
            </div>
        </div>
    </div>
</div>

<style>
    /* Phone-shaped frame so authors preview the survey at a real mobile
       viewport. 375×740 roughly matches iPhone 13 mini / SE3. The screen
       area scrolls internally so long surveys behave like they would on a
       real device. Width is derived from the (clamped) height via
       aspect-ratio on .survey-preview__device-screen — the outer frame
       wraps its child so it stays phone-shaped at any viewport. The
       parent sticky column centers it with flex (see SurveyForm.razor). */
    .survey-preview__device {
        --device-width: 375px;
        --device-height: 740px;
        --device-radius: 42px;
        width: fit-content;
        max-width: 100%;
        margin: 8px auto;
        background: #111827;
        border-radius: var(--device-radius);
        padding: 14px;
        box-shadow: 0 18px 40px -12px rgba(17, 24, 39, 0.35),
                    0 8px 16px -8px rgba(17, 24, 39, 0.25),
                    inset 0 0 0 1.5px #2d3748;
        position: relative;
    }
    .survey-preview__device-notch {
        position: absolute;
        top: 18px;
        left: 50%;
        transform: translateX(-50%);
        width: 110px;
        height: 22px;
        background: #000;
        border-radius: 14px;
        z-index: 2;
    }
    .survey-preview__device-screen {
        background: #ffffff;
        border-radius: calc(var(--device-radius) - 14px);
        overflow: auto;
        /* Adapt to available viewport when the sticky container can't show
           the full --device-height. The 140px subtracts the AppBar-aware
           sticky offset (72) + breathing (16) + device frame margin (16) +
           device frame vertical padding (28) + a small safety margin. Falls
           back to 280px minimum so the phone is still usable at extreme
           zoom levels, and caps at the nominal 740px so a wide viewport
           doesn't stretch the device beyond its intended silhouette. */
        height: clamp(280px, calc(100vh - 140px), var(--device-height));
        /* Width flows from height at a fixed phone ratio so shrinking
           the viewport produces a shorter-AND-narrower phone rather than
           a squat tablet silhouette. 375/812 matches iPhone 13 mini —
           slimmer than the older 375/740 so the device reads as a modern
           phone, not a 2015-era one. */
        aspect-ratio: 375 / 812;
        width: auto;
        padding-top: 40px;
        -webkit-overflow-scrolling: touch;
    }

    .survey-preview__toolbar {
        display: flex;
        justify-content: center;
        margin-bottom: 6px;
    }

    /* The scalebox reserves the SCALED footprint of the frame so the sticky
       rail (an auto-sized grid column in SurveyForm) sizes itself to what's
       actually painted rather than the logical 768/1024px frame. Mobile mode
       is unscaled pass-through. */
    .survey-preview__scalebox {
        width: fit-content;
        max-width: 100%;
        margin: 0 auto;
    }

    /* Tablet: true 768px-wide viewport scaled to half size (≈398px painted). */
    .survey-preview--tablet .survey-preview__scalebox {
        width: calc((768px + 28px) * 0.5);
        height: calc((1024px + 28px) * 0.5 + 16px);
        overflow: hidden;
    }
    .survey-preview--tablet .survey-preview__device {
        --device-radius: 22px;
        transform: scale(0.5);
        transform-origin: top left;
    }
    .survey-preview--tablet .survey-preview__device-screen {
        height: 1024px;
        aspect-ratio: 768 / 1024;
        padding-top: 14px;
    }

    /* Desktop: true 1024px-wide viewport scaled to ≈442px painted. */
    .survey-preview--desktop .survey-preview__scalebox {
        width: calc((1024px + 28px) * 0.42);
        height: calc((768px + 28px) * 0.42 + 16px);
        overflow: hidden;
    }
    .survey-preview--desktop .survey-preview__device {
        --device-radius: 12px;
        transform: scale(0.42);
        transform-origin: top left;
    }
    .survey-preview--desktop .survey-preview__device-screen {
        height: 768px;
        aspect-ratio: 1024 / 768;
        padding-top: 14px;
    }
</style>

@code {
    [Parameter] public SurveyDto? Schema { get; set; }
    [Parameter] public string? Locale { get; set; }

    /// <summary>
    /// Screen id the editor currently has selected. Pushed to the renderer as
    /// a jump signal so the preview follows the author's selection. Null =
    /// don't sync (the preview navigates freely).
    /// </summary>
    [Parameter] public string? ActiveScreenId { get; set; }

    /// <summary>
    /// Bump this every time the parent mutates <see cref="Schema"/> in place.
    /// Reference equality isn't enough — the visual editor updates fields on the
    /// same <c>SurveyDto</c> instance, so the preview would otherwise skip
    /// re-resolution. Parent increments on each keystroke / structural change.
    /// </summary>
    [Parameter] public int SchemaVersion { get; set; }

    // Cache-bust the import URL with the assembly version so a published
    // interop.js change can't be silently shadowed by a stale ES module the
    // browser had pinned from a previous deploy.
    private static readonly string InteropPath =
        $"./_content/ShiftSoftware.ADP.Surveys.Web/js/shift-survey/interop.js?v={typeof(SurveyPreview).Assembly.GetName().Version}";

    // Preview frame width: mobile (375, 1:1) / tablet (768, scaled) /
    // desktop (1024, scaled). Pure CSS — the same <shift-survey> element
    // persists across toggles, so no schema re-push is needed.
    private string previewMode = "mobile";

    private ElementReference surveyElement;
    private IJSObjectReference? interopModule;
    private SurveyDto? lastPushedSource;
    private int lastPushedVersion = -1;
    private string? lastPushedLocale;
    private string? lastPushedActiveScreen;
    private bool submitHandlerInstalled;
    private string? resolveError;
    private bool disposed;

    /// <summary>
    /// Resolves the draft server-side (bankRefs + templateRefs → inline) so the
    /// preview shows exactly what a customer would see. On failure we surface
    /// the server's error copy via the placeholder and retain the same Schema
    /// reference so we don't retry on every re-render.
    /// </summary>
    private async Task<string?> ResolveDraftJson(SurveyDto draft)
    {
        try
        {
            var response = await Http.PostAsJsonAsync(
                $"{SurveysOptions.ResolvedRoutePrefix}Preview",
                draft,
                SurveySchemaSerializer.Options);
            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync();
                resolveError = body.Length > 200 ? body.Substring(0, 200) + "…" : body;
                return null;
            }
            resolveError = null;
            return await response.Content.ReadAsStringAsync();
        }
        catch (Exception ex)
        {
            resolveError = ex.Message;
            return null;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (disposed) return;

        if (Schema is null)
        {
            lastPushedSource = null;
            lastPushedVersion = -1;
            lastPushedLocale = null;
            submitHandlerInstalled = false;
            return;
        }

        var schemaChanged = !ReferenceEquals(Schema, lastPushedSource) || SchemaVersion != lastPushedVersion;
        var localeChanged = Locale != lastPushedLocale;
        var activeScreenChanged = ActiveScreenId != lastPushedActiveScreen;

        if (!schemaChanged && !localeChanged && !activeScreenChanged) return;

        string? resolvedJson = null;
        if (schemaChanged)
        {
            resolvedJson = await ResolveDraftJson(Schema);
            if (disposed) return;
            if (resolvedJson is null)
            {
                // Capture the bad source so we don't retry on every re-render.
                // Author will retype → new SchemaVersion → we try again.
                lastPushedSource = Schema;
                lastPushedVersion = SchemaVersion;
                StateHasChanged();
                return;
            }
        }

        // If a previous render had the element hidden because of an error, the
        // ref we hold is stale. Trigger a re-render so <shift-survey> rebinds.
        if (resolveError is not null)
        {
            resolveError = null;
            StateHasChanged();
            await Task.Yield();
            if (disposed) return;
        }

        try
        {
            interopModule ??= await JS.InvokeAsync<IJSObjectReference>("import", InteropPath);
            if (disposed) return;

            if (!submitHandlerInstalled)
            {
                await interopModule.InvokeVoidAsync("installPreviewSubmitHandler", surveyElement);
                submitHandlerInstalled = true;
            }

            if (resolvedJson is not null)
            {
                await interopModule.InvokeVoidAsync("setSchema", surveyElement, resolvedJson);
                lastPushedSource = Schema;
                lastPushedVersion = SchemaVersion;
            }

            if (Locale != lastPushedLocale)
            {
                await interopModule.InvokeVoidAsync("setLocale", surveyElement, Locale);
                lastPushedLocale = Locale;
            }

            if (ActiveScreenId != lastPushedActiveScreen)
            {
                await interopModule.InvokeVoidAsync("setActiveScreen", surveyElement, ActiveScreenId);
                lastPushedActiveScreen = ActiveScreenId;
            }
        }
        catch (ObjectDisposedException) { /* disposed mid-await; safe to ignore */ }
        catch (JSDisconnectedException) { /* page navigated away */ }
    }

    public async ValueTask DisposeAsync()
    {
        disposed = true;
        if (interopModule is not null)
        {
            try { await interopModule.DisposeAsync(); }
            catch (JSDisconnectedException) { /* page navigated away; ignore */ }
            catch (ObjectDisposedException) { /* already disposed */ }
            interopModule = null;
        }
    }
}
