@attribute [Route($"{SurveyRoutes.Prefix}/{nameof(SurveyForm)}/{{Key?}}")]
@using System.Text.Json
@using ShiftSoftware.ADP.Surveys.Shared.Json

@inherits ShiftForm<SurveyForm, SurveyAdminDTO>

@inject SurveysWebOptions SurveysOptions
@inject SurveyService SurveySvc
@inject MudBlazor.ISnackbar Snackbar

<ShiftEntityForm @bind-Mode="Mode"
                 @bind-Value="TheItem"
                 @ref="FormContainer"
                 Endpoint="@($"{SurveysOptions.ResolvedRoutePrefix}Survey")"
                 Title="Survey"
                 T="SurveyAdminDTO"
                 TypeAuthAction="SurveysActionTree.Surveys"
                 @bind-Key="@Key">

    <ToolbarEndTemplate>
        @if (Mode != FormModes.Create && Key is not null)
        {
            <MudButton StartIcon="@Icons.Material.Filled.Publish"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@publishing"
                       OnClick="OnPublish">
                @(publishing ? "Publishing…" : "Publish")
            </MudButton>
        }
    </ToolbarEndTemplate>

    <ChildContent>
        <MudTextFieldExtended OnlyValidateIfDirty="true"
                              Label="Name"
                              @bind-Value="TheItem.Name"
                              For="@(() => TheItem.Name)" />

        @if (TheItem.PublishedVersionNumber.HasValue)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                Last published version: <b>@TheItem.PublishedVersionNumber</b>
            </MudAlert>
        }

        @*
            JSON editor + live preview side-by-side (stacks below 1024px). Text
            changes deserialize straight into TheItem.Draft so FluentValidation's
            `When(Draft is not null, ...)` inner-validator sees real screens / logic
            and can surface inline errors — not delayed to server-side. The preview
            pane picks up TheItem.Draft on every render; invalid-JSON states clear
            it so the preview shows a placeholder instead of stale content.
        *@
        @{
            // Seed the textarea once from TheItem.Draft — reliable here because
            // we're in the render pass where TheItem is already populated via
            // ShiftEntityForm's @bind-Value. OnParametersSet + OnResult proved
            // unreliable for this timing, but a one-shot inline check runs on
            // every render and catches the first render with a populated Draft.
            if (!draftJsonSeeded && TheItem?.Draft is not null)
            {
                DraftJson = JsonSerializer.Serialize(TheItem.Draft, SurveySchemaSerializer.Pretty);
                draftJsonSeeded = true;
            }
        }
        <div class="survey-form__split">
            <div class="survey-form__editor">
                @* Native <textarea> on purpose. MudTextFieldExtended caches its
                   internal value on first render and drops subsequent parameter
                   updates, so the editor stayed blank after the API load even
                   with @@bind-Value:get/set + InvokeAsync(StateHasChanged). A
                   native element also reads more like what authors expect for
                   a JSON blob — monospace font, fixed rows, no floating label. *@
                <label class="survey-form__editor-label">Draft (SurveyDto JSON)</label>
                <textarea class="survey-form__editor-textarea"
                          rows="24"
                          spellcheck="false"
                          value="@DraftJson"
                          @oninput="OnDraftJsonInput" />
                <p class="survey-form__editor-help">
                    Full SurveyDto — screens, logic, locales. Saved as-is on Save; resolved + frozen on Publish.
                </p>

                @if (parseError is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">
                        JSON parse error: @parseError
                    </MudAlert>
                }
            </div>
            <div class="survey-form__preview">
                <div class="survey-form__preview-header">Live preview</div>
                <SurveyPreview Schema="TheItem.Draft" />
            </div>
        </div>

        <style>
            /* Scoped via the unique class names below; lives in the form so the
             * preview pane owns its own layout without bleeding into consumers. */
            .survey-form__split {
                display: grid;
                grid-template-columns: 1fr;
                gap: 16px;
                align-items: start;
            }
            @@media (min-width: 1024px) {
                .survey-form__split {
                    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
                }
            }
            .survey-form__preview {
                border: 1px solid #d0d5dd;
                border-radius: 8px;
                background: #f7f8fa;
                overflow: hidden;
                min-height: 400px;
            }
            .survey-form__preview-header {
                padding: 8px 12px;
                border-bottom: 1px solid #d0d5dd;
                background: #fff;
                font-size: 0.85rem;
                font-weight: 600;
                color: #555;
            }
            .survey-preview__placeholder {
                padding: 32px;
                text-align: center;
                color: #888;
            }
            .survey-form__editor-label {
                display: block;
                font-weight: 600;
                font-size: 0.85rem;
                color: #555;
                margin-bottom: 6px;
            }
            .survey-form__editor-textarea {
                width: 100%;
                box-sizing: border-box;
                padding: 12px;
                border: 1px solid #d0d5dd;
                border-radius: 8px;
                font-family: ui-monospace, "Cascadia Code", Menlo, Consolas, monospace;
                font-size: 0.85rem;
                line-height: 1.5;
                resize: vertical;
            }
            .survey-form__editor-textarea:focus-visible {
                outline: 2px solid #2563eb;
                outline-offset: 1px;
                border-color: #2563eb;
            }
            .survey-form__editor-help {
                margin: 4px 0 0;
                font-size: 0.8rem;
                color: #666;
            }
        </style>
    </ChildContent>

</ShiftEntityForm>

@code {
    string DraftJson { get; set; } = "";
    string? parseError;
    bool publishing;
    // Tracks whether we've seeded DraftJson from TheItem.Draft yet. After the
    // user touches the textarea, the textarea is the source of truth — we never
    // re-seed or the user would lose mid-edit state.
    bool draftJsonSeeded;

    // Seeding is done inline in the render block — see the top of the
    // ChildContent. Keeping the flag here so the @code block owns its state.

    void OnDraftJsonInput(ChangeEventArgs e)
    {
        OnDraftJsonChanged((e.Value as string) ?? "");
    }

    void OnDraftJsonChanged(string value)
    {
        DraftJson = value;
        if (string.IsNullOrWhiteSpace(value))
        {
            TheItem.Draft = null;
            parseError = null;
            return;
        }
        try
        {
            TheItem.Draft = JsonSerializer.Deserialize<SurveyDto>(value, SurveySchemaSerializer.Options);
            parseError = null;
        }
        catch (JsonException ex)
        {
            parseError = ex.Message;
        }
    }

    async Task OnPublish()
    {
        var idString = Key?.ToString();
        if (string.IsNullOrEmpty(idString)) return;
        publishing = true;
        try
        {
            var response = await SurveySvc.PublishAsync(idString);
            var body = await response.Content.ReadAsStringAsync();
            if (response.IsSuccessStatusCode)
                Snackbar.Add($"Published — {body}", MudBlazor.Severity.Success);
            else
                Snackbar.Add($"Publish failed: {body}", MudBlazor.Severity.Error);
        }
        finally
        {
            publishing = false;
        }
    }
}
