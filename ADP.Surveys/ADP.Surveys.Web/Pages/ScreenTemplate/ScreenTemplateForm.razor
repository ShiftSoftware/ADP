@attribute [Route($"{SurveyRoutes.Prefix}/{nameof(ScreenTemplateForm)}/{{Key?}}")]
@attribute [Authorize]
@using System.Text.Json
@using ShiftSoftware.ADP.Surveys.Shared.Json

@inherits ShiftForm<ScreenTemplateForm, ScreenTemplateAdminDTO>

@inject SurveysWebOptions SurveysOptions

<ShiftEntityForm @bind-Mode="Mode"
                 @bind-Value="TheItem"
                 @ref="FormContainer"
                 Endpoint="@($"{SurveysOptions.ResolvedRoutePrefix}ScreenTemplate")"
                 Title="Screen Template"
                 T="ScreenTemplateAdminDTO"
                 TypeAuthAction="SurveysActionTree.ScreenTemplates"
                 @bind-Key="@Key">

    @{
        // Seed the JSON view in the same render pass TheItem materializes —
        // OnResult + MudTextFieldExtended silently showed an empty editor for
        // loaded rows (see the "OnResult is unreliable" + "MudTextFieldExtended
        // caches its internal value" gotchas).
        if (!ReferenceEquals(seededFor, TheItem))
        {
            seededFor = TheItem;
            templateJson = TheItem?.Template is null
                ? ""
                : JsonSerializer.Serialize(TheItem!.Template, SurveySchemaSerializer.Pretty);
            parseError = null;
        }
        var isReadOnly = Mode == FormModes.View;
    }

    <MudTextFieldExtended OnlyValidateIfDirty="true"
                          Label="Key (reference id used by surveys via templateRef)"
                          @bind-Value="TheItem.Key"
                          For="@(() => TheItem.Key)" />

    <div class="stf__label mt-3">Template (JSON — schema-level ScreenTemplateDto)</div>
    <textarea class="stf__json"
              value="@templateJson"
              @oninput="@((ChangeEventArgs e) => OnTemplateJsonChanged((string?)e.Value ?? ""))"
              disabled="@isReadOnly"
              spellcheck="false"></textarea>
    <div class="stf__hint">Paste a ScreenTemplateDto JSON payload (title, description, banked question refs).</div>

    @if (parseError is not null)
    {
        <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">
            JSON parse error: @parseError
        </MudAlert>
    }

</ShiftEntityForm>

<style>
    .stf__label {
        font-size: 0.85rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 4px;
    }
    .stf__json {
        width: 100%;
        min-height: 320px;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.82rem;
        line-height: 1.5;
        border: 1px solid #d0d5dd;
        border-radius: 6px;
        padding: 10px;
        resize: vertical;
        box-sizing: border-box;
    }
    .stf__hint {
        font-size: 0.75rem;
        color: #888;
        margin-top: 2px;
    }
</style>

@code {
    ScreenTemplateAdminDTO? seededFor;
    string templateJson = "";
    string? parseError;

    void OnTemplateJsonChanged(string value)
    {
        templateJson = value;
        if (string.IsNullOrWhiteSpace(value))
        {
            TheItem.Template = null;
            parseError = null;
            return;
        }
        try
        {
            TheItem.Template = JsonSerializer.Deserialize<ScreenTemplateDto>(value, SurveySchemaSerializer.Options);
            parseError = null;
        }
        catch (JsonException ex)
        {
            parseError = ex.Message;
        }
    }
}
