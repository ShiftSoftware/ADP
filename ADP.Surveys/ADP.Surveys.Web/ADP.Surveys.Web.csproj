<Project Sdk="Microsoft.NET.Sdk.Razor">
	<Import Project="..\..\GlobalSettings.props" />

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<RootNamespace>ShiftSoftware.ADP.Surveys.Web</RootNamespace>
		<BlazorWebAssemblyLoadAllGlobalizationData>true</BlazorWebAssemblyLoadAllGlobalizationData>
		<Authors>Shift Software</Authors>
		<Product>ADP.Surveys</Product>
		<Version>$(ADPVersion)</Version>
		<AssemblyName>ShiftSoftware.ADP.Surveys.Web</AssemblyName>
		<PackageId>ShiftSoftware.ADP.Surveys.Web</PackageId>
		<Title>ShiftSoftware ADP.Surveys — Web</Title>
		<Description>Blazor WebAssembly pages, forms and services for the ShiftSoftware ADP.Surveys package — a dynamic survey platform module.</Description>
		<Copyright>Copyright (c) Shift Software 2026</Copyright>
		<PackageProjectUrl>https://github.com/ShiftSoftware/ADP</PackageProjectUrl>
		<PackageIcon>icon.png</PackageIcon>
		<RepositoryUrl>https://github.com/ShiftSoftware/ADP</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageTags>shift;shiftsoftware;adp;surveys;survey;dynamic;forms;blazor</PackageTags>
		<PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
	</PropertyGroup>

	<ItemGroup>
		<None Include="Images\icon.png" Pack="true" PackagePath="\" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.7" />
		<PackageReference Include="Microsoft.AspNetCore.WebUtilities" Version="10.0.7" />
		<PackageReference Include="Microsoft.Extensions.Configuration" Version="10.0.7" />
		<PackageReference Include="ShiftSoftware.ShiftBlazor" Version="2026.4.28.1" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\ADP.Surveys.Shared\ADP.Surveys.Shared.csproj" />
	</ItemGroup>
</Project>
