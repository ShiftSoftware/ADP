@attribute [Authorize]
@attribute [Route($"/{nameof(ClaimableItemList)}")]

@inject IOptions<ClaimableItemsWebOptions> CIOptions

<ShiftList EntitySet="ClaimableItem"
           Title="Claimable Items"
           T="ClaimableItemListDTO"
           Dense
           FilterPanelDefaultOpen
           EnableFilterPanel
           DisableActionColumn
           ComponentType="typeof(ClaimableItemForm)"
           ShowIDColumn="true"
           HighlightSortedColumn
           TypeAuthAction="CIOptions.Value.ClaimableItemSetupAction"
           EnableExport>

    <Sort Property="x => x.CampaignStartDate" Direction="SortDirection.Descending" />

    <StringFilter Order="0" Property="x => x.Name" Label="Name" Operator="ShiftSoftware.ShiftBlazor.Enums.ODataOperator.Contains" lg="3" md="6" sm="12" xs="12" />
    <StringFilter Order="1" Property="x => x.UniqueReference" Label="Unique Reference" Operator="ShiftSoftware.ShiftBlazor.Enums.ODataOperator.Contains" lg="3" md="6" sm="12" xs="12" />
    <ForeignFilter Order="2" AdditionalParameters='new() { [nameof(ShiftAutocomplete<ClaimableItemListDTO>.GroupSelectedValues)] = false }' Property="x => x.CampaignID" Label="Campaign" DTOType="typeof(CampaignListDTO)" EntitySet="ServiceCampaign" lg="6" md="6" sm="12" xs="12" />
    <DateTimeFilter Order="3" Property="x => x.CampaignStartDate" Label="Campaign Start Date" lg="4" md="6" sm="12" xs="12" />
    <DateTimeFilter Order="4" Property="x => x.CampaignExpireDate" Label="Campaign Expire Date" lg="4" md="6" sm="12" xs="12" />
    <NumberFilter Order="5" Property="x => x.MaximumMileage" Label="Maximum Mileage" Operator="ShiftSoftware.ShiftBlazor.Enums.ODataOperator.GreaterThan" lg="4" md="6" sm="12" xs="12" />
    <EnumFilter Order="6" Property="x => x.CampaignActivationTrigger" Label="Activation Trigger" lg="6" md="6" sm="12" xs="12" />
    <EnumFilter Order="7" Property="x => x.CampaignActivationType" Label="Activation Type" lg="6" md="6" sm="12" xs="12" />

    <PropertyColumn Filterable="false" Property="x => x.Name" Title="Name" CellClass="whitespace-nowrap" />
    <PropertyColumn Filterable="false" Property="x => x.UniqueReference" Title="Unique Reference" CellClass="whitespace-nowrap" HeaderClass="whitespace-nowrap" />
    <ButtonColumn Filterable="false" Property="x => x.CampaignName" KeyPropertyName="@(nameof(ClaimableItemListDTO.CampaignID))" Title="Campaign" CellClass="whitespace-nowrap" ComponentType="typeof(CampaignForm)" />
    <PropertyColumn Filterable="false" Format="yyyy-MM-dd" Property="x => x.CampaignStartDate" Title="Campaign Start Date" HeaderClass="whitespace-nowrap" />
    <PropertyColumn Filterable="false" Format="yyyy-MM-dd" Property="x => x.CampaignExpireDate" Title="Campaign Expire Date" HeaderClass="whitespace-nowrap" />
    <PropertyColumn Filterable="false" Property="x => x.MaximumMileage" Title="Maximum Mileage" CellClass="whitespace-nowrap" HeaderClass="whitespace-nowrap" />


    <PropertyColumn Filterable="false" Property="x => x.ValidityModeText" Title="Validity Mode" CellClass="whitespace-nowrap" HeaderClass="whitespace-nowrap" />
    <PropertyColumn Filterable="false" Property="x => x.Validity" Title="Validity" CellClass="whitespace-nowrap" HeaderClass="whitespace-nowrap" />
    <PropertyColumn Filterable="false" Property="x => x.ActivationTriggerText" Title="Activation Trigger" CellClass="whitespace-nowrap" HeaderClass="whitespace-nowrap" />
    <PropertyColumn Filterable="false" Property="x => x.ActivationTypeText" Title="Activation Type" CellClass="whitespace-nowrap" HeaderClass="whitespace-nowrap" />
</ShiftList>
