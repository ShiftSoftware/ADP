<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\ADP.LookupServices\Lookup.Services\Lookup.Services.csproj" />
	</ItemGroup>

	<ItemGroup>
		<!-- Same Hashids implementation the production apps use (via ShiftEntityHashId), so the
		     generated mock serial numbers match what the real endpoint produces. -->
		<PackageReference Include="Hashids.net" Version="1.7.0" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="NSubstitute" Version="6.0.0" />
	</ItemGroup>

	<Target Name="RunSelfAfterBuild" AfterTargets="Build">
		<Exec Command="dotnet &quot;$(TargetPath)&quot;" />
	</Target>
</Project>
