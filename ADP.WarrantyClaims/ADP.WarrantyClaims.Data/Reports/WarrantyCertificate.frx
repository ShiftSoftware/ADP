        <TextObject Name="TextHeadingTitle" Left="9.45" Top="9.45" Width="727.65" Height="18.9" Text="Warranty Repairs Acceptance Certificate" HorzAlign="Center" Font="Arial, 11pt"/>
        <TextObject Name="TextCertificateNo" Left="9.45" Top="37.8" Width="727.65" Height="18.9" Text="Certificate No. [Header.CertificateNo]" HorzAlign="Center" Font="Arial, 11pt, style=Bold"/>
        <TextObject Name="Text12" Left="9.45" Top="103.95" Width="727.65" Height="170.1" Text="We, the undersigned, representing the Warranty Department of [Header.Distributor] on the one hand, and [Header.Dealer] on the other hand, hereby issue this Certificate under the following terms:&#13;&#10;&#13;&#10;&#13;&#10;1. The warranty services rendered by [Header.Dealer] to Toyota cars, within its designated territory during the period from [Header.StartDate], to [Header.EndDate], have been provided and agreed in full and are in compliance with the terms and conditions of the Agreement with [Header.Distributor].&#13;&#10;&#13;&#10;2. In consideration of the aforementioned services, [Header.Distributor] shall remit payment in accordance with the terms and conditions specified in the Agreement." Font="Arial, 10pt"/>
        <TextObject Name="Text14" Left="9.45" Top="66.15" Width="727.65" Height="18.9" Text="Acknowledgment of Warranty Repairs Performed" HorzAlign="Center" Font="Arial, 11pt"/>
