<Project Sdk="Microsoft.NET.Sdk">
	<Import Project="..\..\GlobalSettings.props" />

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<LangVersion>latest</LangVersion>
		<RootNamespace>ShiftSoftware.ADP.WarrantyClaims.Data</RootNamespace>
		<Authors>Shift Software</Authors>
		<Product>ADP.WarrantyClaims</Product>
		<Version>$(ADPVersion)</Version>
		<AssemblyName>ShiftSoftware.ADP.WarrantyClaims.Data</AssemblyName>
		<PackageId>ShiftSoftware.ADP.WarrantyClaims.Data</PackageId>
		<Title>ShiftSoftware ADP.WarrantyClaims — Data</Title>
		<Description>Entities, repositories, services, AutoMapper profiles and replication wiring for the ShiftSoftware ADP.WarrantyClaims package — the warranty claim module.</Description>
		<Copyright>Copyright (c) Shift Software 2026</Copyright>
		<PackageProjectUrl>https://github.com/ShiftSoftware/ADP</PackageProjectUrl>
		<PackageIcon>icon.png</PackageIcon>
		<RepositoryUrl>https://github.com/ShiftSoftware/ADP</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageTags>shift;shiftsoftware;adp;warranty;warranty-claims;claims;automotive;efcore</PackageTags>
		<PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
	</PropertyGroup>

	<ItemGroup>
		<None Include="Images\icon.png" Pack="true" PackagePath="\" />
	</ItemGroup>

	<ItemGroup>
		<!-- Byte-frozen FastReport templates (moved verbatim from the original host, Phase 3
		     Slice 3.2). Embedded — extracted to a temp file at print time because ShiftEntity.Print
		     only loads from a path today. Consumers rebrand via WarrantyClaimsApiOptions.ReportOverrides. -->
		<EmbeddedResource Include="Reports\WarrantyClaim.frx" />
		<EmbeddedResource Include="Reports\WarrantyCertificate.frx" />
		<EmbeddedResource Include="Reports\WarrantyInvoice.frx" />
		<EmbeddedResource Include="Reports\ManufacturerWarrantyInvoice.frx" />
		<!-- The financial report moved in Phase 3 Slice 3.5 (D23) and is the ONE deliberately
		     genericized template: its baked org labels/expressions were renamed to the module
		     vocabulary (Distributor Margins / Manufacturer Payment / Claim #) rather than kept
		     byte-frozen. Consumers rebrand via ReportOverrides.FinancialReportFrxPath. -->
		<EmbeddedResource Include="Reports\FinancialReport.frx" />
	</ItemGroup>

	<ItemGroup>
		<!-- IHttpClientFactory for the settlement-sheet attachment download. -->
		<PackageReference Include="Microsoft.Extensions.Http" Version="10.0.9" />
		<PackageReference Include="ShiftSoftware.ShiftEntity.EFCore" Version="2026.7.3.1" />
		<PackageReference Include="ShiftSoftware.ShiftEntity.CosmosDbReplication" Version="2026.7.3.1" />
		<!-- FastReport printing (warranty claim / certificate / invoice + manufacturer invoice)
		     moved in from the original host (Phase 3 Slice 3.2). -->
		<PackageReference Include="ShiftSoftware.ShiftEntity.Print" Version="2026.7.3.1" />
		<PackageReference Include="ShiftSoftware.ShiftIdentity.Core" Version="2026.7.3.1" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\ADP.WarrantyClaims.Shared\ADP.WarrantyClaims.Shared.csproj" />
		<!-- Warranty claims certify via the shared Cases Certificate entity. -->
		<ProjectReference Include="..\..\ADP.Cases\ADP.Cases.Data\ADP.Cases.Data.csproj" />
	</ItemGroup>

</Project>
