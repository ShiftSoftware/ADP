<Project Sdk="Microsoft.NET.Sdk.Razor">
	<Import Project="..\..\GlobalSettings.props" />

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<RootNamespace>ShiftSoftware.ADP.WarrantyClaims.Web</RootNamespace>
		<BlazorWebAssemblyLoadAllGlobalizationData>true</BlazorWebAssemblyLoadAllGlobalizationData>
		<Authors>Shift Software</Authors>
		<Product>ADP.WarrantyClaims</Product>
		<Version>$(ADPVersion)</Version>
		<AssemblyName>ShiftSoftware.ADP.WarrantyClaims.Web</AssemblyName>
		<PackageId>ShiftSoftware.ADP.WarrantyClaims.Web</PackageId>
		<Title>ShiftSoftware ADP.WarrantyClaims — Web</Title>
		<Description>Blazor WebAssembly pages and services for the ShiftSoftware ADP.WarrantyClaims package — the warranty claim module.</Description>
		<Copyright>Copyright (c) Shift Software 2026</Copyright>
		<PackageProjectUrl>https://github.com/ShiftSoftware/ADP</PackageProjectUrl>
		<PackageIcon>icon.png</PackageIcon>
		<RepositoryUrl>https://github.com/ShiftSoftware/ADP</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageTags>shift;shiftsoftware;adp;warranty;warranty-claims;claims;automotive;blazor</PackageTags>
		<PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
	</PropertyGroup>

	<ItemGroup>
		<None Include="Images\icon.png" Pack="true" PackagePath="\" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.10" />
		<PackageReference Include="Microsoft.AspNetCore.WebUtilities" Version="10.0.10" />
		<PackageReference Include="Microsoft.Extensions.Configuration" Version="10.0.10" />
		<PackageReference Include="ShiftSoftware.ShiftBlazor" Version="2026.7.21.1" />
		<PackageReference Include="ShiftSoftware.ADP.Models" Version="$(ADPVersion)" Condition="!Exists('..\..\ADP.Models\Models\Models.csproj')" />
		<ProjectReference Include="..\..\ADP.Models\Models\Models.csproj" Condition="Exists('..\..\ADP.Models\Models\Models.csproj')" />
		<!-- WarrantyClaimForm.razor.cs part-lookup / flat-rate use PartLookupDTO + FlatRateDTO. -->
		<PackageReference Include="ShiftSoftware.ADP.Lookup.Services" Version="$(ADPVersion)" Condition="!Exists('..\..\ADP.LookupServices\Lookup.Services\Lookup.Services.csproj')" />
		<ProjectReference Include="..\..\ADP.LookupServices\Lookup.Services\Lookup.Services.csproj" Condition="Exists('..\..\ADP.LookupServices\Lookup.Services\Lookup.Services.csproj')" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\ADP.WarrantyClaims.Shared\ADP.WarrantyClaims.Shared.csproj" />
		<!-- Certificate/Invoice lists render CertificateListDTO + UpdateStatusActionTypes from the Cases engine. -->
		<ProjectReference Include="..\..\ADP.Cases\ADP.Cases.Shared\ADP.Cases.Shared.csproj" />
	</ItemGroup>
</Project>
