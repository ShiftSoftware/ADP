@attribute [Authorize]
@attribute [Route($"/{nameof(WarrantyClaimList)}")]

@inject IWarrantyClaimsCapabilityProvider CapabilityProvider
@inject IOptions<WarrantyClaimsWebOptions> WCOptions
@inject MessageService MessageService
@inject IConfiguration Configuration
@inject IJSRuntime JSRuntime

@inject HttpClient Http
@inject IDialogService DialogService
@inject ITypeAuthService TypeAuthService;

@using ShiftSoftware.ADP.WarrantyClaims.Shared.DTOs
@using ShiftSoftware.ADP.WarrantyClaims.Shared.DTOs.WarrantyClaim
@using ShiftSoftware.ADP.WarrantyClaims.Shared.Enums
@using ShiftSoftware.ADP.Models.Enums
@using ShiftSoftware.ShiftEntity.Model
@using ShiftSoftware.ShiftIdentity.Core.DTOs.Company
@using ShiftSoftware.TypeAuth.Core

@* <pre>
@System.Text.Json.JsonSerializer.Serialize(this.rates, new System.Text.Json.JsonSerializerOptions { WriteIndented = true })
</pre> *@

<ShiftList Title=""
           T="WarrantyClaimListDTO"
           Dense
           Context="listContext"
           EntitySet="WarrantyClaim"
           DisableActionColumn
           ComponentType="typeof(WarrantyClaimForm)"
           ShowIDColumn="false"
           @ref="shiftList"
           EnableSelection
           EnableFilterPanel
           FilterPanelDefaultOpen
           HighlightSortedColumn
           TypeAuthAction="WCOptions.Value.WarrantyClaimAction">

    <ToolbarStartTemplate>
        @if (isDistributor)
        {
            <MudStack Row Class="claim-list-actions">
                <ActionButton Color="Color.Success"
                              Variant="Variant.Outlined"
                              Size="Size.Small"
                              StartIcon="@Icons.Material.Filled.Check"
                              DialogIcon="@Icons.Material.Filled.Check"
                              Confirm
                              DialogColor="Color.Success"
                              OnResult="StatusUpdateResponse"
                              Endpoint="@($"WarrantyClaim/UpdateStatus/{UpdateStatusActionTypes.DistributorAccepted}")"
                              T="WarrantyClaimListDTO">
                    Accept
                </ActionButton>

                <ActionButton Color="Color.Warning"
                              Variant="Variant.Outlined"
                              Size="Size.Small"
                              StartIcon="@Icons.Material.Filled.Warning"
                              DialogIcon="@Icons.Material.Filled.Warning"
                              Confirm
                              DialogTitle="Mark as Error"
                              DialogConfirmText="Save"
                              DialogColor="Color.Warning"
                              OnResult="StatusUpdateResponse"
                              Endpoint="@($"WarrantyClaim/UpdateStatus/{UpdateStatusActionTypes.DistributorError}/{Uri.EscapeDataString(inputText ?? "")}")"
                              T="WarrantyClaimListDTO">
                    <DialogBodyTemplate>
                        <MudTextFieldExtended @bind-Value="inputText" Label="Error Message" />
                    </DialogBodyTemplate>
                    <ChildContent>
                        Error
                    </ChildContent>
                </ActionButton>

                @if (WCOptions.Value.DeliveryDateOverwriteAction is not null && TypeAuthService.CanAccess(WCOptions.Value.DeliveryDateOverwriteAction))
                {
                    <ActionButton Color="Color.Info"
                                  Variant="Variant.Outlined"
                                  Size="Size.Small"
                                  StartIcon="@Icons.Material.Filled.EditCalendar"
                                  DialogIcon="@Icons.Material.Filled.EditCalendar"
                                  Confirm
                                  DialogTitle="Update Delivery Date"
                                  DialogConfirmText="Apply to VIN"
                                  DialogColor="Color.Info"
                                  OnResult="StatusUpdateResponse"
                                  Endpoint="@($"WarrantyClaim/UpdateDeliveryDate/{deliveryDate!.Value.ToString("O")}")"
                                  T="WarrantyClaimListDTO">
                        <DialogBodyTemplate>
                            <MudText Typo="Typo.body2" Class="mb-3">
                                This Delivery Date applied to <strong>all</strong>
                                claims for that VIN — including Certified, Invoiced, and Paid claims. Pre-Delivery claims are not
                                affected. Select claims for a single VIN only.
                            </MudText>
                            <MudDatePickerExtended Required Color="Color.Info" @bind-Date="deliveryDate" Label="Delivery Date" />
                        </DialogBodyTemplate>
                        <ChildContent>
                            Delivery Date
                        </ChildContent>
                    </ActionButton>
                }

                <ActionButton Color="Color.Error"
                              Variant="Variant.Outlined"
                              Size="Size.Small"
                              StartIcon="@Icons.Material.Filled.Error"
                              DialogIcon="@Icons.Material.Filled.Error"
                              Confirm
                              DialogColor="Color.Error"
                              OnResult="StatusUpdateResponse"
                              Endpoint="@($"WarrantyClaim/UpdateStatus/{UpdateStatusActionTypes.DistributorRejected}")"
                              T="WarrantyClaimListDTO">
                    Reject
                </ActionButton>

                <ActionButton Color="Color.Primary"
                              Variant="Variant.Outlined"
                              Size="Size.Small"
                              StartIcon="@Icons.Material.Filled.BookmarkAdded"
                              ComponentType="typeof(WarrantyCertificateForm)"
                              T="WarrantyClaimListDTO">
                    Certify
                </ActionButton>

                @* <ActionButton Color="Color.Default"
                              Variant="Variant.Outlined"
                              Size="Size.Small"
                              StartIcon="@Icons.Material.Filled.CurrencyExchange"
                              DialogIcon="@Icons.Material.Filled.CurrencyExchange"
                              Confirm
                              DialogColor="Color.Default"
                              OnResult="StatusUpdateResponse"
                              Endpoint="@($"WarrantyClaim/RegenerateCSVEntries")"
                              T="WarrantyClaimListDTO">
                    Re-Generate CSV
                </ActionButton> *@
            </MudStack>
        }
        else
        {
            <MudStack Row Class="claim-list-actions">
                <ActionButton Color="Color.Info"
                              Variant="Variant.Outlined"
                              Size="Size.Small"
                              StartIcon="@Icons.Material.Filled.Check"
                              Confirm
                              DialogColor="Color.Info"
                              OnResult="StatusUpdateResponse"
                              Endpoint="@($"WarrantyClaim/UpdateStatus/{UpdateStatusActionTypes.SubmitToDistributor}")"
                              T="WarrantyClaimListDTO">
                    Submit to Distributor
                </ActionButton>
            </MudStack>
        }
    </ToolbarStartTemplate>

    <ToolbarEndTemplate>
        @if (isDistributor)
        {
            <MudStack Row Class="claim-list-actions">
                @*  <ActionButton Color="Color.Tertiary"
                              Variant="Variant.Outlined"
                              Size="Size.Small"
                              StartIcon="@Icons.Material.Filled.Numbers"
                              Confirm
                              DialogConfirmText="Save"
                              DialogIcon="@Icons.Material.Filled.Numbers"
                              DialogTitle="Assign Invoice No."
                              DialogColor="Color.Tertiary"
                              OnResult="StatusUpdateResponse"
                              Endpoint="@($"WarrantyClaim/UpdateStatus/{UpdateStatusActionTypes.AssignInvoiceNo}/{Uri.EscapeDataString(inputText ?? "")}")"
                              T="WarrantyClaimListDTO">
                    <DialogBodyTemplate>
                        <MudTextFieldExtended @bind-Value="inputText" Label="Invoice No." />
                    </DialogBodyTemplate>
                    <ChildContent>
                        Invoice No.
                    </ChildContent>
                </ActionButton> *@

                @* <ActionButton Color="Color.Error"
                              Variant="Variant.Outlined"
                              Size="Size.Small"
                              StartIcon="@Icons.Material.Filled.Error"
                              DialogIcon="@Icons.Material.Filled.Error"
                              DialogColor="Color.Error"
                              OnResult="StatusUpdateResponse"
                              Endpoint="@($"WarrantyClaim/UpdateStatus/{UpdateStatusActionTypes.ManufacturerRejected}")"
                              Confirm
                              T="WarrantyClaimListDTO">
                    Manufacturer Rejected
                </ActionButton> *@

                @if (this.rates is not null)
                {
                    <ActionButton Color="Color.Info"
                                  Variant="Variant.Outlined"
                                  Size="Size.Small"
                                  StartIcon="@Icons.Material.Filled.Download"
                                  DialogIcon="@Icons.Material.Filled.Download"
                                  DialogColor="Color.Info"
                                  OnDefaultDialogOpen="onDefaultDialogOpen"
                                  OnResult="CSVExportResponse"
                                  DialogConfirmText="Export"
                                  Endpoint="@($"WarrantyClaim/ExportManufacturerCSV?invoice={Uri.EscapeDataString(inputText ?? "")}&rates={Uri.EscapeDataString(System.Text.Json.JsonSerializer.Serialize(this.uiRates))}")"
                                  Confirm
                                  T="WarrantyClaimListDTO">
                        <DialogBodyTemplate>
                            @*                             <pre>
                                @System.Text.Json.JsonSerializer.Serialize(this.uiRates, new System.Text.Json.JsonSerializerOptions { WriteIndented = true })
                </pre> *@
                            <MudText>
                                Download the selected records and Mark them as <strong>[@WarrantyManufacturerClaimStatus.Exported.Describe()]</strong>
                            </MudText>
                            <MudItem lg="12" md="12" sm="12" xs="12" Class="mb-3 mt-5">
                                <MudTextFieldExtended @bind-Value="inputText" Label="Invoice Number" />
                            </MudItem>
                            <MudText Class="mb-3 mt-5">
                                Below rates will be used. You can adjust them before exporting if necessary.
                            </MudText>
                            <MudGrid>
                                <MudItem lg="6" md="6" sm="12" xs="12">
                                    <MudNumericFieldExtended @bind-Value="uiRates.PRR" Label="P.W.R / P.R.R" />
                                </MudItem>
                                <MudItem lg="6" md="6" sm="12" xs="12">
                                    <MudNumericFieldExtended @bind-Value="uiRates.LaborExchangeRate" Label="USD -> JPY (Labor)" />
                                </MudItem>
                                <MudItem lg="6" md="6" sm="12" xs="12">
                                    <MudNumericFieldExtended @bind-Value="uiRates.SubletExchangeRate" Label="USD -> JPY (Sublet)" />
                                </MudItem>
                                <MudItem lg="6" md="6" sm="12" xs="12">
                                    <MudNumericFieldExtended @bind-Value="uiRates.PartExchangeRate" Label="USD -> JPY (Parts)" />
                                </MudItem>
                            </MudGrid>
                        </DialogBodyTemplate>
                        <ChildContent>
                            Export / Invoice
                        </ChildContent>
                    </ActionButton>
                }

                @* <ActionButton Color="Color.Success"
                              Variant="Variant.Outlined"
                              Size="Size.Small"
                              StartIcon="@Icons.Material.Filled.Paid"
                              DialogIcon="@Icons.Material.Filled.Paid"
                              DialogColor="Color.Success"
                              OnResult="StatusUpdateResponse"
                              Confirm
                              Endpoint="@($"WarrantyClaim/UpdateStatus/{UpdateStatusActionTypes.ManufacturerPaid}")"
                              T="WarrantyClaimListDTO">
                    Paid
                </ActionButton>

                <ActionButton Color="Color.Dark"
                              Variant="Variant.Outlined"
                              Size="Size.Small"
                              StartIcon="@Icons.Material.Filled.Refresh"
                              DialogIcon="@Icons.Material.Filled.Refresh"
                              DialogColor="Color.Dark"
                              OnResult="StatusUpdateResponse"
                              Confirm
                              Action="@($"WarrantyClaim/UpdateStatus/{UpdateStatusActionTypes.ManufacturerReset}")"
                              T="WarrantyClaimListDTO">
                    Reset
                </ActionButton> *@
            </MudStack>
        }
    </ToolbarEndTemplate>

    <ChildContent>
        <Sort Property="x => x.RepairDate" Direction="SortDirection.Descending" />

        <StringFilter Order="0" Property="x => x.ClaimNumber" Label="Claim No." Operator="ShiftSoftware.ShiftBlazor.Enums.ODataOperator.Contains" lg="3" md="6" sm="12" xs="12" />
        <ForeignFilter Order="1" AdditionalParameters='new() { [nameof(ShiftAutocomplete<WarrantyClaimListDTO>.GroupSelectedValues)] = false }' Property="x => x.CompanyID" Label="Company" DTOType="typeof(CompanyListDTO)" EntitySet="IdentityCompany" BaseUrlKey="ShiftIdentityApi" lg="5" md="6" sm="12" xs="12" />
        <StringFilter Order="2" Property="x => x.VIN" Label="VIN" Operator="ShiftSoftware.ShiftBlazor.Enums.ODataOperator.Contains" lg="4" md="6" sm="12" xs="12" />
        <StringFilter Order="3" Property="x => x.InvoiceNo" Label="Invoice No." Operator="ShiftSoftware.ShiftBlazor.Enums.ODataOperator.Contains" lg="3" md="6" sm="12" xs="12" />
        <StringFilter Order="4" Property="x => x.WarrantyType" Operator="ShiftSoftware.ShiftBlazor.Enums.ODataOperator.Contains" Label="Warranty Type" lg="3" md="6" sm="12" xs="12" />
        <StringFilter Order="5" Property="x => x.SSCCampaignCode" Label="SSC Campaign Code" Operator="ShiftSoftware.ShiftBlazor.Enums.ODataOperator.Contains" lg="3" md="6" sm="12" xs="12" />
        <EnumFilter Order="6" Property="x => x.ClaimStatus" Label="Status" lg="3" md="6" sm="12" xs="12" />
        <EnumFilter Order="7" Property="x => x.ManufacturerStatus" Label="Manufacturer Status" lg="3" md="6" sm="12" xs="12" />

        <DateTimeFilter Order="8" Property="x => x.RepairDate" Label="Repair Date" lg="6" md="6" sm="12" xs="12" />

        <ButtonColumn Filterable="false" ComponentType="typeof(WarrantyClaimForm)" Property="x => x.ClaimNumber" StickyLeft Title="Claim No." Class="whitespace-nowrap" />

        <ButtonColumn Filterable="false" ComponentType="typeof(WarrantyClaimForm)" KeyPropertyName="@nameof(WarrantyClaimListDTO.ReferenceWarrantyClaimID)" Property="x => x.ReferenceWarrantyClaimNumber" Title="Reference Claim No" Class="whitespace-nowrap" />

        <ForeignColumn Title="Company"
                       Filterable="false"
                       T="WarrantyClaimListDTO"
                       CellClass="whitespace-nowrap"
                       TEntity="ShiftSoftware.ShiftIdentity.Core.DTOs.Company.CompanyListDTO"
                       EntitySet="IdentityCompany"
                       BaseUrlKey="ShiftIdentityApi"
                       TProperty="string"
                       Property="x=> x.CompanyID" />

        <PropertyColumn Filterable="false" Property="x => x.VIN" Title="VIN" Class="whitespace-nowrap" />
        <PropertyColumn Filterable="false" Property="x => x.DeliveryDate" Format="yyyy-MM-dd" Title="Delivery Date" Class="whitespace-nowrap" />
        <PropertyColumn Filterable="false" Property="x => x.InvoiceNo" Title="Invoice No." Class="whitespace-nowrap" />
        <PropertyColumn Filterable="false" Property="x => x.DealerCode" Title="Dealer" Class="whitespace-nowrap" />
        <PropertyColumn Filterable="false" Property="x => x.WarrantyType" Title="Warranty Type" Class="whitespace-nowrap" />
        <PropertyColumn Filterable="false" Property="x => x.SSCCampaignCode" Title="SSC Campaign Code" Class="whitespace-nowrap" />

        <PropertyColumn Filterable="false" Format="yyyy-MM-dd" Property="x => x.RepairDate" Title="Repair Date" HeaderClass="whitespace-nowrap" />
        <PropertyColumn Format="F" Property="x => x.ProcessDate" Title="Process Date" HeaderClass="whitespace-nowrap" />
        <PropertyColumn Format="F" Property="x => x.DistributorProcessDate" Title="Distributor Process Date" HeaderClass="whitespace-nowrap" />

        <PropertyColumn Property="x => x.DealerRepairDays" Title="Dealer Process Days" Class="whitespace-nowrap" />
        <PropertyColumn Property="x => x.DistributorRepairDays" Title="Distributor Process Days" Class="whitespace-nowrap" />

        <PropertyColumn Property="x => x.TotalClaimAmount" Title="Total Amount" Class="whitespace-nowrap" />

        @if (isDistributor)
        {
            <PropertyColumn Property="x => x.TotalClaimAmountDistributor" Title="Distributor Amount" Class="whitespace-nowrap" />
        }

        <PropertyColumn Filterable="false" Property="x => x.ClaimStatus" Title="Status" Class="whitespace-nowrap">
            <CellTemplate>
                @if (context.Item.DistributorErrorMessage is not null && context.Item.ClaimStatus == ClaimStatus.RejectedWithError)
                {
                    <MudTooltip Text="@context.Item.DistributorErrorMessage" Placement="Placement.Left">
                        <ClaimStatusChip ClaimStatus="@context.Item.ClaimStatus" />
                    </MudTooltip>
                }
                else
                {
                    <ClaimStatusChip ClaimStatus="@context.Item.ClaimStatus" />
                }
            </CellTemplate>
        </PropertyColumn>

        @if (isDistributor)
        {
            <PropertyColumn Filterable="false" Property="x => x.ManufacturerStatus" Title="Manufacturer Status" Class="whitespace-nowrap">
                <CellTemplate>
                    @if (context.Item.ManufacturerErrorMessage is not null && context.Item.ManufacturerStatus == WarrantyManufacturerClaimStatus.Rejected)
                    {
                        <MudMenu ActivationEvent="MouseEvent.MouseOver" AnchorOrigin="Origin.CenterLeft" TransformOrigin="Origin.CenterRight">
                            <ActivatorContent Context="menuContext">
                                <ManufacturerStatusChip ManufacturerStatus="@context.Item.ManufacturerStatus" />
                            </ActivatorContent>

                            <ChildContent>
                                <MudStack Class="pa-2">
                                    <MudText Style="min-width: 400px;" Typo="Typo.subtitle1" Align="Align.Center" Color="Color.Warning" Class="ml-4">@context.Item.ManufacturerErrorMessage</MudText>

                                    <MudDivider />

                                    <MudButton Variant="Variant.Text"
                                               Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.ContentCopy"
                                               ButtonType="ButtonType.Button"
                                               OnClick="async () => await ReSubmit(context.Item)"
                                               Color="Color.Primary">
                                        Re-Submit
                                    </MudButton>
                                </MudStack>
                            </ChildContent>
                        </MudMenu>
                    }
                    else
                    {
                        <ManufacturerStatusChip ManufacturerStatus="@context.Item.ManufacturerStatus" />
                    }
                </CellTemplate>

            </PropertyColumn>
        }
    </ChildContent>
</ShiftList>

@code {
    private bool isDistributor = false;
    private string? inputText;
    private DateTime? deliveryDate = DateTime.UtcNow.Date;

    private WarrantyRatesDTO uiRates = new WarrantyRatesDTO();

    private WarrantyRatesDTO? rates = null;

    private ShiftList<WarrantyClaimListDTO> shiftList = default!;

    private async Task ReSubmit(WarrantyClaimListDTO item)
    {
        var parameters = new Dictionary<string, object>
        {
            { "ForceSaveAsNew", true }
        };

        await shiftList.OpenDialog(typeof(WarrantyClaimForm), item.ID, ModalOpenMode.Popup, parameters);
    }

    protected override async Task OnInitializedAsync()
    {
        this.isDistributor = CapabilityProvider.IsDistributor;

        // await ShowExportResultFormAsync("warranty-csv-exports/warranty-claims-20251008182645.csv", "1212");

        await base.OnInitializedAsync();
    }

    private ValueTask<bool> onDefaultDialogOpen(SelectStateDTO<WarrantyClaimListDTO> selectState)
    {
        this.inputText = "";

        if (this.rates is not null)
        {
            this.uiRates.ID = rates.ID;
            this.uiRates.LaborExchangeRate = rates.LaborExchangeRate;
            this.uiRates.PartExchangeRate = rates.PartExchangeRate;
            this.uiRates.PRR = rates.PRR;
            this.uiRates.SubletExchangeRate = rates.SubletExchangeRate;


            StateHasChanged();

            return ValueTask.FromResult(true);
        }

        return ValueTask.FromResult(false);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadRates();
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task LoadRates()
    {
        try
        {
            // Phase 3 Slice 3.3: the module API now serves the rates (IWarrantyRatesStore).
            this.rates = (await this.Http.GetFromJsonAsync<WarrantyRatesDTO>($"WarrantyClaim/current-rates"))!;

            StateHasChanged();
        }

        catch
        {
        }
    }

    private ValueTask<bool> StatusUpdateResponse(ShiftEntityResponse<IList<WarrantyClaimListDTO>> data)
    {
        this.inputText = null;

        var res = data;

        if (res.Entity?.Count > 0)
        {
            this.MessageService.Warning($"({res.Entity!.Count}) claims has been updated.");
        }
        else if (res.Entity?.Count == 0)
        {
            this.MessageService.Error($"No claims were updated.");
        }
        else if (res.Message is null)
        {
            this.MessageService.Error("An error occurred while updating the claims.");
        }

        return new ValueTask<bool>(true);
    }

    private async Task ShowExportResultFormAsync(string csvExportPath, string invoiceNumber)
    {
        var parameters = new DialogParameters<WarrantyClaimExportResultForm>
        {
            { x => x.CSVExportPath, csvExportPath },
            { x => x.InvoiceNumber, invoiceNumber },
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = false,
            MaxWidth = MaxWidth.Small
        };

        await DialogService.ShowAsync<WarrantyClaimExportResultForm>(
            "Export Results",
            parameters,
            options
        );
    }

    private async ValueTask<bool> CSVExportResponse(ShiftEntityResponse<IList<WarrantyClaimListDTO>> data)
    {
        var res = data;

        if (res.Entity?.Count > 0)
        {
            this.MessageService.Warning($"({res.Entity!.Count}) claims has been updated.");

            this.rates = System.Text.Json.JsonSerializer.Deserialize<WarrantyRatesDTO>(data.Additional!["Rates"].ToString()!)!;

            await this.ShowExportResultFormAsync(
                data.Additional!["CSVExportPath"]!.ToString()!,
                data.Additional!["InvoiceNumber"]!.ToString()!
            );
        }
        else if (res.Entity?.Count == 0)
        {
            this.MessageService.Error($"No claims were updated.");
        }
        else if (res.Message is null)
        {
            this.MessageService.Error("An error occurred while updating the claims.");
        }

        return true;
    }
}