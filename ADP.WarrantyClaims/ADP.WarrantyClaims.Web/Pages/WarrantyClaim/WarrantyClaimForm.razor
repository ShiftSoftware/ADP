                        {
                            if (string.IsNullOrWhiteSpace(TheItem?.Franchise) || TheItem?.YearModel == null || string.IsNullOrWhiteSpace(TheItem?.VIN_WMI) || string.IsNullOrWhiteSpace(TheItem?.VIN_VDS))
