@inject IConfiguration Configuration
@inject IJSRuntime JSRuntime
@inject HttpClient Http

<MudDialog>
    <DialogContent>
        <MudStack Row Spacing="4" AlignItems="AlignItems.Center" Justify="Justify.Center" Class="pb-4 pt-1">
            <MudCard Elevation="3">
                <MudCardContent>
                    <MudText Typo="Typo.subtitle1">Manufacturer CSV</MudText>
                    <MudText Typo="Typo.body2">To be imported to the Manufacturer System</MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton OnClick="DownloadCSVFile" StartIcon="@Icons.Material.Filled.Download" Variant="Variant.Text" Color="Color.Info">Download</MudButton>
                </MudCardActions>
            </MudCard>

            <MudCard Elevation="3">
                <MudCardContent>
                    <MudText Typo="Typo.subtitle1">Manufacturer Invoice</MudText>
                    <MudText Typo="Typo.body2">To be Reimbursed by Manufacturer</MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton OnClick="DownloadInvoice" Variant="Variant.Text" Color="Color.Warning">
                        @if (Printing)
                        {
                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                            <MudText Class="ms-2">Download</MudText>
                        }
                        else
                        {
                            <MudIcon Class="me-2" Icon="@Icons.Material.Filled.Download"></MudIcon>
                            <MudText>Download</MudText>
                        }
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudStack>
    </DialogContent>
</MudDialog>

@code {
    [Parameter]
    public string CSVExportPath { get; set; } = default!;

    [Parameter]
    public string InvoiceNumber { get; set; } = default!;

    private async Task DownloadCSVFile()
    {
        await JSRuntime.InvokeVoidAsync("open", $"{Configuration.GetValue<string>("BaseUrl")}WarrantyClaim/DownloadCSV/{CSVExportPath}", "_blank");
    }

    private bool Printing;

    private async Task DownloadInvoice()
    {
        if (Printing)
            return;

        Printing = true;

        // await Task.Delay(2000);

        var printToken = (await this.Http.GetStringAsync($"{Configuration.GetValue<string>("BaseUrl")}WarrantyClaim/print-invoice-token/{this.InvoiceNumber}"))!;

        Printing = false;

        var printUrl = $"{Configuration.GetValue<string>("BaseUrl")}WarrantyClaim/print-invoice/{this.InvoiceNumber}?{printToken}";

        await JSRuntime.InvokeVoidAsync("open", printUrl, "_blank");
    }
}