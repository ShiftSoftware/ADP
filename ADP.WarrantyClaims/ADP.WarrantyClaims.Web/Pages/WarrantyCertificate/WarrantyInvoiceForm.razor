@attribute [Route($"/{nameof(WarrantyInvoiceForm)}/{{Key?}}")]

@using ShiftSoftware.ADP.WarrantyClaims.Shared.DTOs.Certificate
@using ShiftSoftware.ADP.WarrantyClaims.Shared.DTOs.WarrantyClaim
@using ShiftSoftware.ADP.WarrantyClaims.Shared.Enums
@using ShiftSoftware.ADP.Models.Enums

@inherits ShiftForm<WarrantyInvoiceForm, CertificateDTO>

@inject IOptions<WarrantyClaimsWebOptions> WCOptions

<ShiftEntityForm @bind-Mode="Mode"
                 @bind-Value="TheItem"
                 @ref="FormContainer"
                 Endpoint="WarrantyInvoice"
                 Title="Invoice"
                 TypeAuthAction="WCOptions.Value.InvoicesAction"
                 ShowPrint
                 HideEdit
                 HideRevisions
                 @bind-Key="@Key">
    <MudGrid Spacing="4">
        @if (Mode != FormModes.Create)
        {
            <MudItem lg="12" md="12" sm="12" xs="12">
                <MudAlert Icon="@Icons.Material.Filled.Numbers" Severity="Severity.Info">Invoice No: <strong>@(TheItem.CertificateNo)</strong></MudAlert>
            </MudItem>
        }

        <MudItem lg="12" md="12" sm="12" xs="12">
            <MudDatePickerExtended Label="Invoice Date"
                                   Clearable="true"
                                   @bind-Date="TheItem.InvoiceDate"
                                   For="() => TheItem.InvoiceDate" />
        </MudItem>

        <MudItem lg="6" md="6" sm="6" xs="6">
            <MudDatePickerExtended Label="Period Start"
                                   Clearable="true"
                                   @bind-Date="TheItem.PeriodStartDate"
                                   For="() => TheItem.PeriodStartDate" />
        </MudItem>

        <MudItem lg="6" md="6" sm="6" xs="6">
            <MudDatePickerExtended Label="Period End"
                                   Clearable="true"
                                   @bind-Date="TheItem.PeriodEndDate"
                                   For="() => TheItem.PeriodEndDate" />
        </MudItem>

        <MudItem lg="12" md="12" sm="12" xs="12" Class="">
            <MudCard Elevation="2">
                <MudCardHeader Class="pt-1 pb-1 background-gray">
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle2">Claims</MudText>
                    </CardHeaderContent>
                </MudCardHeader>

                <MudCardContent Class="pt-2 pb-2">
                    <MudGrid Spacing="3">
                        <MudItem lg="11" md="11" sm="11" xs="11">
                            <MudGrid Spacing="3" Style="align-items: baseline;">
                                <MudItem lg="3" md="3" sm="3" xs="3">
                                    <MudText Class="mud-text-with-border pb-3" Typo="Typo.subtitle2">Claim No.</MudText>
                                </MudItem>

                                <MudItem lg="3" md="3" sm="3" xs="3">
                                    <MudText Class="mud-text-with-border pb-3" Typo="Typo.subtitle2">Dealer Process Date</MudText>
                                </MudItem>

                                <MudItem lg="3" md="3" sm="3" xs="3">
                                    <MudText Class="mud-text-with-border pb-3" Typo="Typo.subtitle2">Distributor Process Date</MudText>
                                </MudItem>

                                <MudItem lg="3" md="3" sm="3" xs="3">
                                    <MudText Class="mud-text-with-border pb-3" Typo="Typo.subtitle2">Type</MudText>
                                </MudItem>
                            </MudGrid>
                        </MudItem>

                        <MudItem lg="1" md="1" sm="1" xs="1"></MudItem>

                        @foreach (var line in TheItem.WarrantyClaims)
                        {
                            <MudItem lg="11" md="11" sm="11" xs="11">
                                <MudGrid Spacing="3" Style="align-items: baseline;">
                                    <MudItem Class="pt-1 pb-1" lg="3" md="3" sm="3" xs="3">
                                        <ShiftAutocomplete Label=""
                                                           Value="line.WarrantyClaim"
                                                           TEntitySet="WarrantyClaimListDTO"
                                                           EntitySet="WarrantyClaim"
                                                           Filter="x=> x.Add(f => {f.Field = nameof(WarrantyClaimListDTO.ClaimStatus); f.Value = ClaimStatus.Accepted;})"
                                                           ValueChanged="(value) => WarrantyClaimSelectionChange(line, value)"
                                                           For="() => line.WarrantyClaim" />
                                    </MudItem>

                                    <MudItem Class="pt-1 pb-1" lg="3" md="3" sm="3" xs="3">
                                        <MudDatePicker Label=""
                                                       ReadOnly
                                                       AdornmentIcon=""
                                                       @bind-Date="line.ProcessDate"
                                                       DateFormat="yyyy-MM-dd" />
                                    </MudItem>

                                    <MudItem Class="pt-1 pb-1" lg="3" md="3" sm="3" xs="3">
                                        <MudDatePicker Label=""
                                                       ReadOnly
                                                       AdornmentIcon=""
                                                       @bind-Date="line.DistributorProcessDate"
                                                       DateFormat="yyyy-MM-dd" />
                                    </MudItem>

                                    <MudItem Class="pt-1 pb-1" lg="3" md="3" sm="3" xs="3">
                                        <MudTextField Label=""
                                                      ReadOnly
                                                      @bind-Value="line.WarrantyType" />
                                    </MudItem>
                                </MudGrid>
                            </MudItem>

                            @if (Mode > FormModes.Archive)
                            {
                                <MudItem lg="1" md="1" sm="1" xs="1">
                                    <MudIconButton ButtonType="ButtonType.Button"
                                                   Style="margin:0px; padding:0; margin-top: 3px;"
                                                   Variant="Variant.Outlined"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   OnClick="@(() => TheItem.WarrantyClaims.Remove(line))"
                                                   Icon="@Icons.Material.Filled.Delete" />
                                </MudItem>
                            }
                        }

                        @if (Mode > FormModes.Archive)
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Info"
                                       Style="margin:auto; margin-top:15px;"
                                       Size="Size.Small"
                                       OnClick="@(() => TheItem.WarrantyClaims.Add(new()))"
                                       StartIcon="@Icons.Material.Filled.Add">
                                Add a Claim
                            </MudButton>
                        }
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

</ShiftEntityForm>

@code {
    [Parameter]
    public SelectState<ShiftSoftware.ADP.WarrantyClaims.Shared.DTOs.WarrantyClaim.WarrantyClaimListDTO>? Selected { get; set; }

    protected override Task OnParametersSetAsync()
    {
        if (Selected is not null)
        {
            foreach (var item in Selected.Items)
            {
                this.TheItem.WarrantyClaims.Add(
                    new WarrantyCertificateLineDTO
                        {
                            WarrantyClaim = new ShiftEntitySelectDTO { Value = item!.ID!, Text = item!.ClaimNumber },
                            ProcessDate = item.ProcessDate?.DateTime,
                            DistributorProcessDate = item.DistributorProcessDate?.DateTime,
                            WarrantyType = item.WarrantyType
                        });
            }

            this.Selected = null;
        }

        return base.OnParametersSetAsync();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        // if (firstRender)
        // {
        //     if (Mode == FormModes.Create)
        //     {
        //         TheItem.CertificateDate = DateTime.Now;

        //         TheItem.PeriodStartDate = new DateTime(2024, 12, 1);
        //         TheItem.PeriodEndDate = new DateTime(2024, 12, 31);

        //         TheItem.CertificateLines.Add(
        //             new CertificateLineDTO()
        //                 {
        //                     WarrantyClaim = new ShiftEntitySelectDTO { Value = "13", Text = "1000001" },
        //                     ProcessDate = DateTime.Now,
        //                     DistributorProcessDate = DateTime.Now,
        //                     WarrantyType = "VE"
        //                 });

        //         StateHasChanged();
        //     }
        // }

        return base.OnAfterRenderAsync(firstRender);
    }

    private void WarrantyClaimSelectionChange(WarrantyCertificateLineDTO line, ShiftEntitySelectDTO? value)
    {
        var claim = value?.Data as WarrantyClaimListDTO;

        if (claim is not null)
        {
            line.WarrantyClaim = value;
            line.ProcessDate = claim.ProcessDate?.DateTime;
            line.DistributorProcessDate = claim.DistributorProcessDate?.DateTime;
            line.WarrantyType = claim.WarrantyType;
        }
        else
        {
            line.WarrantyClaim = null;
            line.ProcessDate = null;
            line.DistributorProcessDate = null;
            line.WarrantyType = null;
        }
    }
}